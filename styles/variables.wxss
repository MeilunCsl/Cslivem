/* styles/variables.wxss - Cslivem 品牌设计系统 */

page {
  /* ===== Cslivem Brand Colors ===== */
  --csl-ink: #0A0F1A;
  --csl-primary: #5B4CFF;
  --csl-blue: #3A7BFF;
  --csl-cyan: #00D4D9;
  --csl-surface: #FFFFFF;
  --csl-surface-muted: #F2F4F8;
  --csl-line: #E7EAF0;
  --csl-text-secondary: #7B8197;

  /* Brand Gradient */
  --csl-gradient: linear-gradient(135deg, #5B4CFF 0%, #3A7BFF 52%, #00D4D9 100%);
  --csl-gradient-angle: 135deg;

  /* Aliases for backward compat */
  --color-primary: #5B4CFF;
  --color-primary-light: #3A7BFF;
  --color-primary-bg: #EDE9FF;
  --color-bg: #F2F4F8;
  --color-card: #FFFFFF;
  --color-text: #0A0F1A;
  --color-text-secondary: #7B8197;
  --color-text-placeholder: #B0B8C9;
  --color-success: #24A148;
  --color-warning: #F59E0B;
  --color-error: #DC3545;
  --color-info: #3A7BFF;
  --color-border: #E7EAF0;
  --color-divider: #F2F4F8;

  /* ===== Radius ===== */
  --csl-radius-input: 48rpx;
  --csl-radius-card: 40rpx;
  --csl-radius-button: 999rpx;
  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 32rpx;
  --radius-xl: 48rpx;
  --radius-full: 999rpx;

  /* ===== Shadows ===== */
  --shadow-card: 0 8rpx 32rpx rgba(10, 15, 26, 0.06);
  --shadow-input: 0 4rpx 24rpx rgba(91, 76, 255, 0.12);
  --shadow-fab: 0 16rpx 48rpx rgba(91, 76, 255, 0.32);
  --shadow-send: 0 8rpx 32rpx rgba(91, 76, 255, 0.36);

  /* ===== Spacing ===== */
  --csl-page-x: 48rpx;
  --csl-section: 64rpx;
  --csl-control-height: 104rpx;
  --spacing-xs: 8rpx;
  --spacing-sm: 16rpx;
  --spacing-md: 24rpx;
  --spacing-lg: 48rpx;
  --spacing-xl: 64rpx;

  /* ===== Typography ===== */
  --font-family: "Inter", "PingFang SC", "Microsoft YaHei", -apple-system, BlinkMacSystemFont, sans-serif;
  --font-size-hero: 56rpx;
  --font-size-title-lg: 44rpx;
  --font-size-title-md: 36rpx;
  --font-size-body: 32rpx;
  --font-size-caption: 24rpx;
  --font-size-mini: 20rpx;
  --line-height-title: 1.3;
  --line-height-body: 1.6;
  --font-weight-bold: 700;
  --font-weight-semibold: 600;
  --font-weight-normal: 400;

  /* ===== Animation ===== */
  --ease-out: cubic-bezier(0.16, 1, 0.3, 1);
  --ease-spring: cubic-bezier(0.34, 1.56, 0.64, 1);
}