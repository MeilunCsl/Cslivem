/* styles/mixins.wxss - Cslivem 通用工具类 */

.flex { display: flex; }
.flex-col { display: flex; flex-direction: column; }
.flex-row { display: flex; flex-direction: row; }
.flex-wrap { flex-wrap: wrap; }
.flex-1 { flex: 1; }
.items-center { align-items: center; }
.justify-center { justify-content: center; }
.justify-between { justify-content: space-between; }
.justify-end { justify-content: flex-end; }

.text-primary { color: var(--color-primary); }
.text-secondary { color: var(--color-text-secondary); }
.text-bold { font-weight: var(--font-weight-bold); }
.text-center { text-align: center; }
.text-ellipsis { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

.card {
  background: var(--color-card);
  border-radius: var(--csl-radius-card, 40rpx);
  padding: var(--spacing-md);
  box-shadow: var(--shadow-card);
}

.btn-primary {
  background: var(--csl-gradient);
  color: #FFFFFF;
  border-radius: var(--csl-radius-button, 999rpx);
  height: var(--csl-control-height, 104rpx);
  line-height: var(--csl-control-height, 104rpx);
  text-align: center;
  font-size: var(--font-size-body);
  font-weight: var(--font-weight-semibold);
}

.tag {
  display: inline-block;
  font-size: var(--font-size-caption);
  padding: 6rpx 16rpx;
  border-radius: var(--radius-full);
  background: var(--csl-surface-muted, #F2F4F8);
  color: var(--color-text-secondary);
}

.safe-bottom { padding-bottom: env(safe-area-inset-bottom); }

.page-container {
  padding: 0 var(--csl-page-x, 48rpx);
  padding-bottom: calc(200rpx + env(safe-area-inset-bottom));
}

.divider { height: 2rpx; background: var(--color-divider); margin: var(--spacing-md) 0; }

.hidden { display: none !important; }

/* ===== Page Entry Animations ===== */
.anim-fade {
  opacity: 0;
  transform: translateY(24rpx);
  transition: opacity 0.5s ease, transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
}
.anim-fade.anim-show {
  opacity: 1;
  transform: translateY(0);
}
.anim-fade-up {
  opacity: 0;
  transform: translateY(40rpx);
  transition: opacity 0.6s ease, transform 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
}
.anim-fade-up.anim-show {
  opacity: 1;
  transform: translateY(0);
}
.anim-scale-in {
  opacity: 0;
  transform: scale(0.92);
  transition: opacity 0.4s ease, transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
}
.anim-scale-in.anim-show {
  opacity: 1;
  transform: scale(1);
}
.anim-d1 { transition-delay: 0.06s; }
.anim-d2 { transition-delay: 0.12s; }
.anim-d3 { transition-delay: 0.18s; }
.anim-d4 { transition-delay: 0.24s; }
.anim-d5 { transition-delay: 0.30s; }

/* ===== Interaction Feedback ===== */
.press {
  opacity: 0.7;
  transform: scale(0.97);
  transition: all 0.15s ease;
}
.btn-press {
  opacity: 0.75;
  transform: scale(0.96);
  transition: all 0.12s ease;
}
.chip-press {
  opacity: 0.7;
  transform: scale(0.95);
}
.item-press {
  background: var(--csl-surface-muted, #F2F4F8);
}
