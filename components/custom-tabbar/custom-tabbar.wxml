<!-- components/custom-tabbar/custom-tabbar.wxml -->
<view class="tabbar">
  <view class="tabbar-inner" style="opacity: {{tabReady ? 1 : 0}}; transform: translateY({{tabReady ? 0 : 16}}rpx);">
    <view class="tab-item {{selected === 0 ? 'active' : ''}}" bindtap="switchTab" data-index="0" data-url="/pages/home/home" hover-class="tab-press">
      <image class="tab-icon" src="/assets/icons/{{selected === 0 ? 'home-active' : 'home'}}.png" mode="aspectFit" />
      <text class="tab-text">首页</text>
    </view>
    <view class="tab-item {{selected === 1 ? 'active' : ''}}" bindtap="switchTab" data-index="1" data-url="/pages/notes/notes" hover-class="tab-press">
      <image class="tab-icon" src="/assets/icons/{{selected === 1 ? 'notes-active' : 'notes'}}.png" mode="aspectFit" />
      <text class="tab-text">知识</text>
    </view>
    <view class="tab-item tab-center" bindtap="togglePanel">
      <view class="fab {{showPanel ? 'fab-rotated' : ''}}">
        <text class="fab-icon">+</text>
      </view>
    </view>
    <view class="tab-item {{selected === 2 ? 'active' : ''}}" bindtap="switchTab" data-index="2" data-url="/pages/calendar/calendar" hover-class="tab-press">
      <image class="tab-icon" src="/assets/icons/{{selected === 2 ? 'calendar-active' : 'calendar'}}.png" mode="aspectFit" />
      <text class="tab-text">日历</text>
    </view>
    <view class="tab-item {{selected === 3 ? 'active' : ''}}" bindtap="switchTab" data-index="3" data-url="/pages/tools/tools" hover-class="tab-press">
      <image class="tab-icon" src="/assets/icons/{{selected === 3 ? 'tools-active' : 'tools'}}.png" mode="aspectFit" />
      <text class="tab-text">工具</text>
    </view>
    <view class="tab-indicator {{indicatorClass}}"></view>
  </view>
</view>

<!-- 快捷记录面板 -->
<view class="quick-overlay {{showPanel ? 'show' : ''}}" catchtap="hidePanel"></view>
<view class="quick-panel {{showPanel ? 'panel-in' : ''}}" catchtap="noop">
  <view class="quick-panel-title">快捷记录</view>
  <view class="quick-actions-grid">
    <view class="quick-action-item" bindtap="onAction" data-type="text" hover-class="action-press">
      <view class="quick-action-icon">📝</view>
      <text>文字</text>
    </view>
    <view class="quick-action-item" bindtap="onAction" data-type="photo" hover-class="action-press">
      <view class="quick-action-icon">📷</view>
      <text>拍照</text>
    </view>
    <view class="quick-action-item" bindtap="onAction" data-type="voice" hover-class="action-press">
      <view class="quick-action-icon">🎤</view>
      <text>语音</text>
    </view>
    <view class="quick-action-item" bindtap="onAction" data-type="scan" hover-class="action-press">
      <view class="quick-action-icon">📋</view>
      <text>扫描</text>
    </view>
  </view>
</view>
