/* components/custom-tabbar/custom-tabbar.wxss - Cslivem 品牌 */

.tabbar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 999;
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(24px);
  border-top: 1rpx solid var(--color-border, #E7EAF0);
}

.tabbar-inner {
  display: flex;
  justify-content: space-around;
  align-items: center;
  height: 110rpx;
  padding-bottom: env(safe-area-inset-bottom);
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  height: 100%;
  color: var(--color-text-secondary, #7B8197);
  font-size: 20rpx;
  position: relative;
  transition: color 0.2s ease;
}

.tab-item.active {
  color: var(--color-primary, #5B4CFF);
}

.tab-icon {
  width: 44rpx;
  height: 44rpx;
  margin-bottom: 4rpx;
}

.tab-text {
  font-size: 20rpx;
  line-height: 1;
  font-weight: 500;
}

/* 中央 FAB "+" 按钮 */
.tab-center {
  position: relative;
  top: -30rpx;
}

.fab {
  width: 108rpx;
  height: 108rpx;
  border-radius: 50%;
  background: var(--csl-gradient, linear-gradient(135deg, #5B4CFF 0%, #3A7BFF 52%, #00D4D9 100%));
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
  font-weight: 300;
  box-shadow: var(--shadow-fab, 0 16rpx 48rpx rgba(91, 76, 255, 0.32));
  transition: transform 0.3s var(--ease-spring, ease);
}

.fab-rotate {
  transform: rotate(45deg);
}

/* 快速记录面板 */
.quick-panel {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(10, 15, 26, 0.4);
  z-index: -1;
  opacity: 0;
  transition: opacity 0.3s ease;
  pointer-events: none;
}

.quick-panel.show {
  z-index: 1000;
  opacity: 1;
  pointer-events: auto;
}

.quick-panel-content {
  position: absolute;
  bottom: calc(140rpx + env(safe-area-inset-bottom));
  left: 32rpx;
  right: 32rpx;
  background: #FFFFFF;
  border-radius: 40rpx;
  padding: 40rpx;
  box-shadow: 0 20rpx 60rpx rgba(10, 15, 26, 0.15);
}

.quick-panel-title {
  font-size: 36rpx;
  font-weight: 700;
  text-align: center;
  margin-bottom: 36rpx;
  color: var(--color-text, #0A0F1A);
}

.quick-actions-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24rpx;
}

.quick-action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.quick-action-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 28rpx;
  background: var(--color-bg, #F2F4F8);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
}

.quick-action-item text {
  font-size: 24rpx;
  color: var(--color-text-secondary, #7B8197);
}