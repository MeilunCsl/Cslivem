/* components/custom-tabbar/custom-tabbar.wxss — 低圆角悬浮导航栏 */

.tabbar {
  position: fixed;
  left: 48rpx;
  right: 48rpx;
  bottom: calc(env(safe-area-inset-bottom) + 28rpx);
  z-index: 100;
  transition: opacity 260ms ease, transform 260ms ease;
}

.tabbar-inner {
  position: relative;
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  align-items: center;
  height: 120rpx;
  border-radius: 26rpx;
  padding: 0;
  background: linear-gradient(110deg, rgba(99, 82, 255, 0.06) 0%, rgba(255, 255, 255, 0.92) 40%, rgba(255, 255, 255, 0.92) 60%, rgba(31, 212, 224, 0.05) 100%);
  border: 1rpx solid rgba(255, 255, 255, 0.85);
  box-shadow: none;
}

/* ===== 导航项 ===== */
.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 120rpx;
  position: relative;
  z-index: 2;
  transition: transform 200ms ease, color 200ms ease, opacity 200ms ease;
}

.tab-press {
  transform: scale(0.94);
}

.tab-icon {
  width: 40rpx;
  height: 40rpx;
  margin-bottom: 8rpx;
  transition: transform 200ms ease;
}

.tab-item.active .tab-icon {
  transform: translateY(-4rpx) scale(1.05);
}

.tab-text {
  font-size: 23rpx;
  line-height: 1;
  font-weight: 400;
  color: #8791aa;
  opacity: 0.92;
  transition: color 200ms ease, font-weight 200ms ease;
}

.tab-item.active .tab-text {
  color: #5b4cff;
  font-weight: 600;
  opacity: 1;
}

/* ===== 选中指示线 ===== */
.tab-indicator {
  position: absolute;
  bottom: 16rpx;
  width: 44rpx;
  height: 5rpx;
  border-radius: 3rpx;
  z-index: 1;
  background: linear-gradient(90deg, #6352ff 0%, #3a7bff 55%, #20bcd9 100%);
  transition: transform 240ms cubic-bezier(0.22, 1, 0.36, 1);
}

/* ===== 中央 + 按钮 ===== */
.tab-center {
  position: relative;
}

.fab {
  position: relative;
  width: 94rpx;
  height: 94rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #7257ff 0%, #4775ff 45%, #11c4e2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 7rpx solid rgba(255, 255, 255, 0.9);
  box-shadow: none;
  transform: translateY(-6rpx);
  transition: transform 220ms ease, box-shadow 220ms ease;
  z-index: 3;
}

.fab:active {
  transform: translateY(-6rpx) scale(0.94);
  box-shadow: 0 4rpx 12rpx rgba(74, 91, 255, 0.10);
}

.fab-rotated {
  transform: translateY(-6rpx) rotate(45deg);
}

.fab-icon {
  font-size: 58rpx;
  font-weight: 300;
  color: #ffffff;
  line-height: 1;
}

/* ===== 快速记录面板 ===== */
.quick-panel {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(10, 15, 26, 0);
  z-index: -1;
  pointer-events: none;
  transition: background 300ms ease;
}

.quick-panel.show {
  z-index: 98;
  background: rgba(10, 15, 26, 0.35);
  pointer-events: auto;
}

.quick-panel-content {
  position: absolute;
  bottom: -400rpx;
  left: 32rpx;
  right: 32rpx;
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 40rpx;
  box-shadow: 0 16rpx 48rpx rgba(10, 15, 26, 0.10);
  transition: bottom 280ms cubic-bezier(0.22, 1, 0.36, 1), opacity 260ms ease;
  opacity: 0;
}

.panel-in {
  bottom: calc(190rpx + env(safe-area-inset-bottom));
  opacity: 1;
}

.quick-panel-title {
  font-size: 32rpx;
  font-weight: 700;
  text-align: center;
  margin-bottom: 32rpx;
  color: #0A0F1A;
}

.quick-actions-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24rpx;
}

.quick-action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.action-press {
  transform: scale(0.9);
  opacity: 0.7;
}

.quick-action-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  background: #F2F4F8;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  transition: background 160ms ease;
}

.quick-action-item:active .quick-action-icon {
  background: #EDE9FF;
}

.quick-action-item text {
  font-size: 22rpx;
  color: #7B8197;
}