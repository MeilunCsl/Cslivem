/* components/custom-tabbar/custom-tabbar.wxss - 胶囊悬挂式 + 渐变 */

.tabbar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 999;
  /* 底部留出悬挂间距 */
  padding: 0 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
}

.tabbar-inner {
  display: flex;
  justify-content: space-around;
  align-items: center;
  height: 112rpx;
  /* 胶囊圆角 */
  border-radius: 999rpx;
  /* 渐变背景：品牌色半透明 */
  background: linear-gradient(
    135deg,
    rgba(91, 76, 255, 0.08) 0%,
    rgba(58, 123, 255, 0.06) 52%,
    rgba(0, 212, 217, 0.05) 100%
  );
  backdrop-filter: blur(32px);
  -webkit-backdrop-filter: blur(32px);
  /* 悬挂阴影 */
  box-shadow:
    0 8rpx 40rpx rgba(91, 76, 255, 0.12),
    0 2rpx 12rpx rgba(10, 15, 26, 0.06),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.8);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
}

/* ===== Tab 项 ===== */
.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  height: 100%;
  color: var(--color-text-secondary, #7B8197);
  font-size: 20rpx;
  position: relative;
  transition: color 0.2s ease;
}

.tab-item.active {
  color: var(--color-primary, #5B4CFF);
}

.tab-press {
  transform: scale(0.88);
  opacity: 0.7;
}

.tab-icon {
  width: 44rpx;
  height: 44rpx;
  margin-bottom: 4rpx;
  transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.tab-item.active .tab-icon {
  transform: scale(1.12) translateY(-2rpx);
}

.tab-text {
  font-size: 20rpx;
  line-height: 1;
  font-weight: 500;
  transition: all 0.2s ease;
}

.tab-item.active .tab-text {
  font-weight: 600;
}

/* 选中指示点 */
.tab-dot {
  position: absolute;
  bottom: 2rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: var(--color-primary, #5B4CFF);
  animation: dot-in 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
}

@keyframes dot-in {
  0% { transform: scale(0) translateY(8rpx); opacity: 0; }
  100% { transform: scale(1) translateY(0); opacity: 1; }
}

/* ===== 中央 FAB ===== */
.tab-center {
  position: relative;
  top: -36rpx;
}

.fab {
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  background: var(--csl-gradient, linear-gradient(135deg, #5B4CFF 0%, #3A7BFF 52%, #00D4D9 100%));
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow:
    0 12rpx 40rpx rgba(91, 76, 255, 0.35),
    0 4rpx 16rpx rgba(91, 76, 255, 0.2);
  transition: all 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
  position: relative;
  z-index: 2;
  border: 4rpx solid rgba(255, 255, 255, 0.9);
}

.fab:active {
  transform: scale(0.88);
}

.fab-active {
  transform: rotate(45deg);
}

.fab-icon {
  font-size: 44rpx;
  font-weight: 300;
  line-height: 1;
  transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.fab-active .fab-icon {
  transform: rotate(-45deg);
}

/* FAB 光环呼吸 */
.fab-ring {
  position: absolute;
  top: -16rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 136rpx;
  height: 136rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(91, 76, 255, 0.1) 0%, transparent 70%);
  z-index: 1;
  animation: ring-breathe 2.5s ease-in-out infinite;
}

@keyframes ring-breathe {
  0%, 100% { opacity: 0.4; transform: translateX(-50%) scale(1); }
  50% { opacity: 0.8; transform: translateX(-50%) scale(1.18); }
}

/* ===== 快速记录面板 ===== */
.quick-panel {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(10, 15, 26, 0);
  z-index: -1;
  pointer-events: none;
  transition: background 0.3s ease;
}

.quick-panel.show {
  z-index: 1000;
  background: rgba(10, 15, 26, 0.45);
  pointer-events: auto;
}

.quick-panel-content {
  position: absolute;
  bottom: -400rpx;
  left: 32rpx;
  right: 32rpx;
  background: #FFFFFF;
  border-radius: 40rpx;
  padding: 40rpx;
  box-shadow: 0 20rpx 60rpx rgba(10, 15, 26, 0.15);
  transition: bottom 0.35s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.3s ease;
  opacity: 0;
}

.panel-in {
  bottom: calc(180rpx + env(safe-area-inset-bottom));
  opacity: 1;
}

.quick-panel-title {
  font-size: 34rpx;
  font-weight: 700;
  text-align: center;
  margin-bottom: 36rpx;
  color: var(--color-text, #0A0F1A);
}

.quick-actions-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24rpx;
}

.quick-action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.action-press {
  transform: scale(0.88);
  opacity: 0.7;
}

.quick-action-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 28rpx;
  background: var(--color-bg, #F2F4F8);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  transition: background 0.2s ease;
}

.quick-action-item:active .quick-action-icon {
  background: var(--color-primary-bg, #EDE9FF);
}

.quick-action-item text {
  font-size: 24rpx;
  color: var(--color-text-secondary, #7B8197);
}