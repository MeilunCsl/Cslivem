/* components/custom-tabbar/custom-tabbar.wxss */

.tabbar {
  position: fixed;
  left: 48rpx;
  right: 48rpx;
  bottom: calc(env(safe-area-inset-bottom) + 28rpx);
  z-index: 100;
  background: transparent;
}

.tabbar-inner {
  position: relative;
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  align-items: center;
  height: 120rpx;
  border-radius: 26rpx;
  overflow: hidden;
  padding: 0;
  background: rgba(255, 255, 255, 0.96);
  border: none; box-shadow: 0 -2rpx 16rpx rgba(0,0,0,0.06);
  transition: opacity 260ms ease, transform 260ms ease;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 120rpx;
  position: relative;
  z-index: 2;
  transition: transform 200ms ease, color 200ms ease, opacity 200ms ease;
}

.tab-press { transform: scale(0.94); }


.tab-icon-text {
  font-size: 38rpx;
  margin-bottom: 6rpx;
  line-height: 1;
  transition: transform 200ms ease;
}
.tab-item.active .tab-icon-text {
  transform: translateY(-4rpx) scale(1.1);
}
.tab-icon {
  width: 40rpx;
  height: 40rpx;
  margin-bottom: 8rpx;
  transition: transform 200ms ease;
}

.tab-item.active 
.tab-icon-text {
  font-size: 38rpx;
  margin-bottom: 6rpx;
  line-height: 1;
  transition: transform 200ms ease;
}
.tab-item.active .tab-icon-text {
  transform: translateY(-4rpx) scale(1.1);
}
.tab-icon {
  transform: translateY(-4rpx) scale(1.05);
}

.tab-text {
  font-size: 23rpx;
  line-height: 1;
  font-weight: 400;
  color: #8791aa;
  opacity: 0.92;
  transition: color 200ms ease, font-weight 200ms ease;
}

.tab-item.active .tab-text {
  color: #5b4cff;
  font-weight: 600;
  opacity: 1;
}

.tab-indicator {
  position: absolute;
  bottom: 16rpx;
  width: 44rpx;
  height: 5rpx;
  border-radius: 3rpx;
  z-index: 1;
  background: linear-gradient(90deg, #6352ff 0%, #3a7bff 55%, #20bcd9 100%);
  transition: left 240ms cubic-bezier(0.22, 1, 0.36, 1);
  transform: translateX(-50%);
}

.tab-indicator.pos-0 { left: 10%; }
.tab-indicator.pos-1 { left: 30%; }
.tab-indicator.pos-2 { left: 50%; }
.tab-indicator.pos-3 { left: 70%; }
.tab-indicator.pos-4 { left: 90%; }

.tab-center { position: relative; }

.fab {
  position: relative;
  width: 94rpx;
  height: 94rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #7257ff 0%, #4775ff 45%, #11c4e2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 7rpx solid rgba(255, 255, 255, 0.9);
  transform: translateY(-6rpx);
  transition: transform 220ms ease;
  z-index: 3;
}

.fab:active { transform: translateY(-6rpx) scale(0.94); }
.fab-rotated { transform: translateY(-6rpx) rotate(45deg); }
.fab-icon { font-size: 58rpx; font-weight: 300; color: #ffffff; line-height: 1; }

.quick-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0);
  z-index: -1;
  pointer-events: none;
  transition: background 280ms ease;
}

.quick-overlay.show {
  z-index: 99;
  background: rgba(10, 15, 26, 0.30);
  pointer-events: auto;
}

.quick-panel {
  position: fixed;
  left: 32rpx;
  right: 32rpx;
  bottom: -500rpx;
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 40rpx;
  box-shadow: 0 12rpx 40rpx rgba(10, 15, 26, 0.08);
  z-index: 100;
  opacity: 0;
  pointer-events: none;
  transition: bottom 280ms cubic-bezier(0.22, 1, 0.36, 1), opacity 240ms ease;
}

.panel-in {
  bottom: calc(190rpx + env(safe-area-inset-bottom));
  opacity: 1;
  pointer-events: auto;
}

.quick-panel-title {
  font-size: 32rpx;
  font-weight: 700;
  text-align: center;
  margin-bottom: 32rpx;
  color: #0A0F1A;
}

.quick-actions-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24rpx;
}

.quick-action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.action-press { transform: scale(0.9); opacity: 0.7; }

.quick-action-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  background: #F2F4F8;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  transition: background 160ms ease;
}

.quick-action-item:active .quick-action-icon { background: #EDE9FF; }
.quick-action-item text { font-size: 22rpx; color: #7B8197; }

/* Badge */
.tab-badge {
  position: absolute; top: 4rpx; right: 12rpx;
  min-width: 32rpx; height: 32rpx; padding: 0 8rpx;
  background: #FF6B6B; border-radius: 16rpx;
  display: flex; align-items: center; justify-content: center;
}
.tab-badge text { font-size: 18rpx; color: #FFF; font-weight: 600; line-height: 1; }
