<!-- components/nav-bar/nav-bar.wxml - 自定义顶部导航栏 -->
<view class="nav-bar" style="padding-top: {{statusBarHeight}}px;">
  <view class="nav-bar-inner">
    <view class="nav-left" wx:if="{{showBack}}" bindtap="onBack">
      <text class="nav-back-icon">‹</text>
    </view>
    <view class="nav-left" wx:else>
      <slot name="left"></slot>
    </view>
    <view class="nav-title">
      <text wx:if="{{title}}">{{title}}</text>
      <slot name="title" wx:else></slot>
    </view>
    <view class="nav-right">
      <slot name="right"></slot>
    </view>
  </view>
</view>
<!-- 占位，防止内容被固定导航栏遮挡 -->
<view style="height: {{statusBarHeight + 44}}px;" wx:if="{{fixed}}"></view>
