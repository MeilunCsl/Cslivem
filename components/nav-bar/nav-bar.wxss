/* components/nav-bar/nav-bar.wxss */
.nav-bar {
  background: var(--color-bg, #F7F7FA);
  position: relative;
  z-index: 100;
}

.nav-bar-inner {
  display: flex;
  align-items: center;
  height: 88rpx;
  padding: 0 24rpx;
}

.nav-left {
  width: 80rpx;
  display: flex;
  align-items: center;
}

.nav-back-icon {
  font-size: 48rpx;
  font-weight: 300;
  color: var(--color-text, #17171C);
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-text, #17171C);
}

.nav-right {
  width: 80rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}
