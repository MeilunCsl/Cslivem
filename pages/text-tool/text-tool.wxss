/* pages/text-tool/text-tool.wxss */
.page { height: 100vh; background: var(--color-bg); display: flex; flex-direction: column; }
.nav-bar { display: flex; align-items: center; height: 88rpx; padding: 0 24rpx; background: var(--color-card); border-bottom: 1rpx solid var(--color-divider); }
.nav-back { font-size: 48rpx; color: var(--color-primary); padding: 0 16rpx; }
.nav-title { flex: 1; text-align: center; font-size: 32rpx; font-weight: 600; color: var(--color-text); }
.content { flex: 1; padding: 24rpx var(--csl-page-x); }

.input-section { background: var(--color-card); border-radius: var(--radius-lg); padding: 20rpx; margin-bottom: 16rpx; }
.input-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12rpx; }
.input-label { font-size: 26rpx; font-weight: 600; color: var(--color-text); }
.input-actions { display: flex; gap: 12rpx; }
.mini-btn { padding: 8rpx 20rpx; background: var(--csl-surface-muted); border-radius: var(--radius-full); font-size: 24rpx; color: var(--color-primary); }
.btn-press { opacity: 0.7; }
.text-area { width: 100%; min-height: 160rpx; font-size: 28rpx; color: var(--color-text); line-height: 1.6; box-sizing: border-box; }

.stats-bar { display: flex; gap: 8rpx; margin-bottom: 16rpx; }
.stat-item { flex: 1; background: var(--color-card); border-radius: var(--radius-md); padding: 12rpx 8rpx; text-align: center; }
.stat-val { display: block; font-size: 32rpx; font-weight: 700; color: var(--color-primary); }
.stat-lbl { display: block; font-size: 20rpx; color: var(--color-text-secondary); }

.actions-grid { display: flex; flex-wrap: wrap; gap: 12rpx; margin-bottom: 16rpx; }
.action-item { padding: 16rpx 28rpx; background: var(--color-card); border-radius: var(--radius-md); border: 1rpx solid var(--color-border); font-size: 26rpx; color: var(--color-text); }

.output-section { background: var(--color-card); border-radius: var(--radius-lg); padding: 20rpx; }
.output-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12rpx; }
.output-label { font-size: 26rpx; font-weight: 600; color: var(--color-text); }
.output-area { background: var(--csl-surface-muted); border-radius: var(--radius-md); padding: 12rpx; }
