<!-- pages/note-detail/note-detail.wxml -->
<view class="page">
  <view style="height: {{statusBarHeight}}px;"></view>
  
  <view class="top-bar anim-fade {{ready ? 'anim-show' : ''}}">
    <view class="back-btn" bindtap="goBack" hover-class="press">← 返回</view>
    <view class="action-btn graph-btn" bindtap="openGraph" hover-class="press">🗘️ 图谱</view>
    <view class="top-actions">
      <view class="action-btn {{note.isFavorite ? 'fav-active' : ''}}" bindtap="toggleFavorite" hover-class="press">
        {{note.isFavorite ? '★' : '☆'}}
      </view>
      <view class="action-btn" bindtap="toggleEdit" hover-class="press">
        {{isEditing ? '取消' : '编辑'}}
      </view>
      <view class="action-btn" bindtap="onShareNote" hover-class="press">分享</view>
      <view class="action-btn delete-btn" bindtap="deleteNote" hover-class="press">删除</view>
    </view>
  </view>

  <scroll-view scroll-y class="detail-scroll" enhanced show-scrollbar="{{false}}">
    <view class="detail-container">
      <view class="title-section anim-fade anim-d1 {{ready ? 'anim-show' : ''}}">
        <text class="note-title" wx:if="{{!isEditing}}">{{note.title}}</text>
        <input class="title-input" wx:else value="{{note.title}}" placeholder="输入标题" />
      </view>

      <view class="meta-section anim-fade anim-d2 {{ready ? 'anim-show' : ''}}">
        <text class="meta-item">{{note.updatedAt}}</text>
        <text class="meta-dot">·</text>
        <text class="meta-item">{{note.source}}</text>
        <text class="meta-dot">·</text>
        <text class="meta-item">{{note.category}}</text>
      </view>

      <view class="tags-section anim-fade anim-d3 {{ready ? 'anim-show' : ''}}">
        <view class="tag-item" wx:for="{{note.tags}}" wx:key="*this">
          <text class="tag-text">{{item}}</text>
          <text class="tag-remove" catchtap="removeTag" data-tag="{{item}}">×</text>
        </view>
        <view class="add-tag-btn" bindtap="showAddTag" wx:if="{{!showTagInput}}" hover-class="press">+ 标签</view>
        <view class="tag-input-wrap" wx:if="{{showTagInput}}">
          <input class="tag-input" value="{{newTag}}" bindinput="onTagInput" placeholder="新标签" focus="{{showTagInput}}" bindconfirm="confirmAddTag" />
          <text class="tag-confirm" bindtap="confirmAddTag">✓</text>
        </view>
      </view>


      <!-- AI Panel -->
      <view class="ai-section anim-fade anim-d3 {{ready ? 'anim-show' : ''}}">
        <view class="ai-toggle" bindtap="toggleAiPanel" hover-class="press">
          <text class="ai-icon">✨</text>
          <text class="ai-label">AI 助手</text>
          <text class="ai-arrow">{{showAiPanel ? '▲' : '▼'}}</text>
        </view>
        <view class="ai-panel" wx:if="{{showAiPanel}}">
          <view class="ai-actions">
            <view class="ai-btn" bindtap="onAiSummarize" hover-class="press">
              <text class="ai-btn-text">{{aiLoading ? '生成中...' : 'AI 摘要'}}</text>
            </view>
            <view class="ai-btn" bindtap="onAiSuggestTags" hover-class="press">
              <text class="ai-btn-text">{{aiLoading ? '推荐中...' : '推荐标签'}}</text>
            </view>
            <view class="ai-btn" bindtap="onAiSuggestRelated" hover-class="press">
              <text class="ai-btn-text">{{aiLoading ? '搜索中...' : '关联推荐'}}</text>
            </view>
          </view>
          <view class="ai-result" wx:if="{{aiSummary}}">
            <view class="ai-result-header">
              <text class="ai-result-title">AI 摘要</text>
              <view class="ai-apply-btn" bindtap="onApplyAiSummary" hover-class="press"><text>应用</text></view>
            </view>
            <text class="ai-result-text">{{aiSummary}}</text>
          </view>
          <view class="ai-result" wx:if="{{aiTags.length > 0}}">
            <view class="ai-result-header">
              <text class="ai-result-title">推荐标签</text>
              <view class="ai-apply-btn" bindtap="onApplyAllAiTags" hover-class="press"><text>全部应用</text></view>
            </view>
            <view class="ai-tags-wrap">
              <view class="ai-tag-item" wx:for="{{aiTags}}" wx:key="*this" bindtap="onApplyAiTag" data-tag="{{item}}" hover-class="press">
                <text class="ai-tag-text">+ {{item}}</text>
              </view>
            </view>
          </view>

          <!-- Related Nodes -->
          <view class="ai-result" wx:if="{{aiRelated.length > 0}}">
            <view class="ai-result-header">
              <text class="ai-result-title">关联内容</text>
            </view>
            <view class="ai-related-list">
              <view class="ai-related-item" wx:for="{{aiRelated}}" wx:key="id" bindtap="onGoRelatedNode" data-id="{{item.id}}" data-type="{{item.type}}" hover-class="press">
                <text class="ai-related-label">{{item.label}}</text>
                <text class="ai-related-type">{{item.type}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>

      <view class="content-section anim-fade anim-d4 {{ready ? 'anim-show' : ''}}">
        <rich-text class="content-text" wx:if="{{!isEditing && note.content}}" nodes="{{parsedContent}}" bindtap="onContentTap"></rich-text>
        <textarea class="content-editor" wx:if="{{isEditing}}" value="{{editContent}}" bindinput="onContentInput" placeholder="输入内容..." auto-height />
        <view class="empty-content" wx:if="{{!isEditing && !note.content}}">
          <text class="empty-hint">暂无内容，点击编辑开始记录</text>
        </view>
      </view>

      <view class="save-section anim-fade anim-d5 {{ready ? 'anim-show' : ''}}" wx:if="{{isEditing}}">
        <view class="save-btn" bindtap="saveNote" hover-class="press">保存</view>
      </view>

      <!-- Backlinks -->
      <view class="backlinks-section anim-fade anim-d5 {{ready ? 'anim-show' : ''}}" wx:if="{{backlinks.length > 0}}">
        <text class="backlinks-title">🔗 被引用 ({{backlinks.length}})</text>
        <view class="backlink-item" wx:for="{{backlinks}}" wx:key="id" bindtap="onTapBacklink" data-id="{{item.id}}" hover-class="press">
          <text class="backlink-title">{{item.title || '未命名笔记'}}</text>
          <text class="backlink-summary">{{item.summary}}</text>
        </view>
      </view>
    </view>
  </scroll-view>
</view>