<!-- pages/chat/chat.wxml -->
<view class="page">
  <view style="height: {{statusBarHeight}}px;"></view>

  <view class="nav-bar">
    <view class="nav-back" bindtap="onBack" hover-class="nav-press">‹</view>
    <view class="nav-title">{{conversation.title || '新对话'}}</view>
    <view class="nav-more" bindtap="onMore">⋯</view>
  </view>

  <scroll-view scroll-y class="msg-scroll" enhanced show-scrollbar="{{false}}">
    <view class="msg-list">
      <view class="msg-empty" wx:if="{{messages.length === 0 && !sending}}">
        <text class="empty-icon">💬</text>
        <text class="empty-text">开始你的对话吧</text>
        <text class="empty-hint">发送文本、图片或语音</text>
      </view>

      <block wx:for="{{groupedMessages}}" wx:key="time">
        <view class="time-group">
          <text class="time-label">{{item.time}}</text>
        </view>
        <view class="msg-item {{m.role}} {{m.isError ? 'msg-error' : ''}}" wx:for="{{item.messages}}" wx:for-item="m" wx:key="id" bindlongpress="onMessageLongPress" data-id="{{m.id}}" data-role="{{m.role}}">
          <view class="msg-avatar" wx:if="{{m.role === 'assistant'}}">
            <text class="avatar-text">AI</text>
          </view>
          <view class="msg-body">
            <view class="msg-bubble">
              <text class="msg-content">{{m.content}}</text>
            </view>
            <view class="msg-meta">
              <text class="msg-model" wx:if="{{m.model}}">{{m.model}}</text>
              <text class="msg-retry" wx:if="{{m.isError}}" bindtap="onRetry" data-id="{{m.id}}">↻ 重试</text>
            </view>
          </view>
          <view class="msg-avatar user-avatar" wx:if="{{m.role === 'user'}}">
            <text class="avatar-text">👤</text>
          </view>
        </view>
      </block>

      <view class="msg-item assistant" wx:if="{{sending && !isStreaming}}">
        <view class="msg-avatar">
          <text class="avatar-text">AI</text>
        </view>
        <view class="msg-body">
          <view class="msg-bubble thinking-bubble">
            <view class="thinking-dots">
              <view class="dot dot1"></view>
              <view class="dot dot2"></view>
              <view class="dot dot3"></view>
            </view>
            <text class="thinking-text">正在思考...</text>
          </view>
        </view>
      </view>

      <view class="msg-item assistant" wx:if="{{isStreaming}}">
        <view class="msg-avatar">
          <text class="avatar-text">AI</text>
        </view>
        <view class="msg-body">
          <view class="msg-bubble">
            <text class="msg-content">{{streamingContent}}▌</text>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>

  <view class="input-bar">
    <view class="action-btns">
      <view class="action-btn" bindtap="onChooseImage">📷</view>
      <view class="action-btn" bindtap="onStartRecord" wx:if="{{!recording}}">🎤</view>
      <view class="action-btn recording" bindtap="onStopRecord" wx:if="{{recording}}">⏹</view>
    </view>
    <view class="input-wrap">
      <input class="msg-input" placeholder="输入消息..." value="{{inputText}}" bindinput="onInput" bindconfirm="onSend" confirm-type="send" />
    </view>
    <view class="send-btn {{inputText ? 'active' : ''}}" bindtap="onSend" hover-class="send-press">
      <text class="send-arrow">↑</text>
    </view>
  </view>

  <view class="actions-overlay {{showActions ? 'show' : ''}}" bindtap="hideActions" catchtouchmove="hideActions"></view>
  <view class="actions-panel {{showActions ? 'show' : ''}}" catchtap="noop">
    <view class="action-item" bindtap="onCopyMessage">
      <text class="action-icon">📋</text>
      <text>复制</text>
    </view>
    <view class="action-item" bindtap="onSaveAsNote" wx:if="{{selectedMsgRole === 'assistant'}}">
      <text class="action-icon">📝</text>
      <text>保存为笔记</text>
    </view>
    <view class="action-item" bindtap="onExtractKnowledge" wx:if="{{selectedMsgRole === 'assistant'}}">
      <text class="action-icon">💡</text>
      <text>提取知识点</text>
    </view>
    <view class="action-item" bindtap="onIngestToGraph" wx:if="{{selectedMsgRole === 'assistant'}}">
      <text class="action-icon">🕸</text>
      <text>转知识图谱</text>
    </view>
    <view class="action-item action-danger" bindtap="onDeleteMessage">
      <text class="action-icon">🗑</text>
      <text>删除</text>
    </view>
  </view>
</view>
