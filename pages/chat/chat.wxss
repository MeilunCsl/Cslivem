/* pages/chat/chat.wxss */
.page { height: 100vh; background: var(--color-bg); display: flex; flex-direction: column; }

/* Nav */
.nav-bar { display: flex; align-items: center; height: 88rpx; padding: 0 24rpx; background: var(--color-card); border-bottom: 1rpx solid var(--color-divider); z-index: 10; }
.nav-back { font-size: 48rpx; font-weight: 300; color: var(--color-primary); padding: 0 16rpx; }
.nav-press { opacity: 0.6; }
.nav-title { flex: 1; text-align: center; font-size: 32rpx; font-weight: 600; color: var(--color-text); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.nav-more { font-size: 36rpx; color: var(--color-text-secondary); padding: 0 16rpx; }

/* Messages */
.msg-scroll { flex: 1; height: 0; }
.msg-list { padding: 24rpx var(--csl-page-x); padding-bottom: 200rpx; }
.msg-empty { display: flex; flex-direction: column; align-items: center; padding: 160rpx 0; gap: 12rpx; }
.empty-icon { font-size: 80rpx; opacity: 0.4; }
.empty-text { font-size: 30rpx; color: var(--color-text-secondary); }
.empty-hint { font-size: 24rpx; color: var(--color-text-placeholder); }

/* Time Group */
.time-group { display: flex; justify-content: center; padding: 20rpx 0 12rpx; }
.time-label { font-size: 22rpx; color: var(--color-text-placeholder); background: var(--csl-surface-muted); padding: 6rpx 20rpx; border-radius: var(--radius-full); }

/* Message Item */
.msg-item { display: flex; align-items: flex-start; gap: 16rpx; margin-bottom: 20rpx; }
.msg-item.user { flex-direction: row-reverse; }
.msg-item.assistant { flex-direction: row; }

.msg-avatar { width: 64rpx; height: 64rpx; border-radius: 50%; background: var(--csl-gradient); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.user-avatar { background: var(--color-primary); }
.avatar-text { font-size: 24rpx; color: #FFF; font-weight: 600; }

.msg-body { max-width: 75%; display: flex; flex-direction: column; }

/* Bubble */
.msg-bubble { padding: 20rpx 28rpx; border-radius: 24rpx; word-break: break-all; line-height: 1.6; }
.user .msg-bubble { background: var(--color-primary); color: #FFFFFF; border-bottom-right-radius: 8rpx; }
.assistant .msg-bubble { background: var(--color-card); color: var(--color-text); border-bottom-left-radius: 8rpx; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05); }
.msg-error .msg-bubble { background: #FFF5F5; border: 1rpx solid #FECACA; }

.msg-content { font-size: 30rpx; }

/* Meta */
.msg-meta { display: flex; align-items: center; gap: 12rpx; margin-top: 6rpx; padding: 0 8rpx; }
.msg-model { font-size: 20rpx; color: var(--color-text-placeholder); }
.msg-retry { font-size: 22rpx; color: var(--color-primary); font-weight: 500; }

/* Thinking Animation */
.thinking-bubble { display: flex; align-items: center; gap: 12rpx; }
.thinking-dots { display: flex; gap: 6rpx; }
.dot { width: 10rpx; height: 10rpx; border-radius: 50%; background: var(--color-primary); animation: bounce 1.4s ease-in-out infinite; }
.dot1 { animation-delay: 0s; }
.dot2 { animation-delay: 0.2s; }
.dot3 { animation-delay: 0.4s; }
@keyframes bounce { 0%, 80%, 100% { transform: translateY(0); opacity: 0.4; } 40% { transform: translateY(-12rpx); opacity: 1; } }
.thinking-text { font-size: 26rpx; color: var(--color-text-secondary); }

/* Input */
.input-bar { display: flex; align-items: center; gap: 16rpx; padding: 16rpx 32rpx; padding-bottom: calc(16rpx + env(safe-area-inset-bottom)); background: var(--color-card); border-top: 1rpx solid var(--color-divider); z-index: 10; }
.input-wrap { flex: 1; }
.msg-input { width: 100%; height: 80rpx; padding: 0 28rpx; background: var(--csl-surface-muted); border-radius: var(--radius-full); font-size: 28rpx; color: var(--color-text); box-sizing: border-box; }
.send-btn { width: 72rpx; height: 72rpx; border-radius: 50%; background: var(--color-border); display: flex; align-items: center; justify-content: center; transition: all 0.2s ease; flex-shrink: 0; }
.send-btn.active { background: var(--csl-gradient); }
.send-press { transform: scale(0.9); }
.send-arrow { font-size: 32rpx; font-weight: 700; color: #FFFFFF; }

/* Actions Panel */
.actions-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0); z-index: -1; pointer-events: none; transition: background 0.28s ease; }
.actions-overlay.show { z-index: 199; background: rgba(10,15,26,0.45); pointer-events: auto; }
.actions-panel { position: fixed; left: 32rpx; right: 32rpx; bottom: -400rpx; background: #FFFFFF; border-radius: 28rpx; padding: 12rpx; z-index: 200; transition: bottom 0.28s cubic-bezier(0.22,1,0.36,1); }
.actions-panel.show { bottom: calc(180rpx + env(safe-area-inset-bottom)); }
.action-item { display: flex; align-items: center; gap: 16rpx; padding: 24rpx 32rpx; font-size: 30rpx; color: var(--color-text); border-radius: 16rpx; }
.action-item:active { background: var(--csl-surface-muted); }
.action-icon { font-size: 32rpx; }
.action-danger { color: var(--color-error); }
