/* pages/stats/stats.wxss */
@import '../../styles/variables.wxss';
@import '../../styles/mixins.wxss';

.page { display: flex; flex-direction: column; height: 100vh; background: var(--color-bg); }
.page-scroll { flex: 1; }
.content { padding: 32rpx 40rpx; padding-bottom: calc(120rpx + env(safe-area-inset-bottom)); }

.header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 32rpx; }
.page-title { font-size: 44rpx; font-weight: 700; color: var(--color-text); }
.header-actions { display: flex; gap: 16rpx; }
.refresh-btn, .export-btn { padding: 10rpx 24rpx; border-radius: 999rpx; font-size: 24rpx; color: var(--color-primary); background: var(--color-primary-bg); }

.overview-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20rpx; margin-bottom: 32rpx; }
.overview-card { background: var(--color-card); border-radius: 24rpx; padding: 28rpx; display: flex; flex-direction: column; align-items: center; }
.ov-val { font-size: 48rpx; font-weight: 700; color: var(--color-primary); }
.ov-label { font-size: 24rpx; color: var(--color-text); margin-top: 8rpx; font-weight: 500; }
.ov-sub { font-size: 22rpx; color: var(--color-text-secondary); margin-top: 4rpx; }

.section { background: var(--color-card); border-radius: 24rpx; padding: 28rpx; margin-bottom: 20rpx; }
.section-title { font-size: 28rpx; font-weight: 600; color: var(--color-text); margin-bottom: 20rpx; }
.detail-row { display: flex; justify-content: space-between; align-items: center; padding: 12rpx 0; border-bottom: 1rpx solid var(--color-border); }
.detail-row:last-child { border-bottom: none; }
.detail-label { font-size: 26rpx; color: var(--color-text); }
.detail-value { font-size: 26rpx; color: var(--color-text-secondary); font-weight: 500; }

.storage-bar-bg { height: 12rpx; background: var(--csl-surface-muted); border-radius: 999rpx; overflow: hidden; margin-bottom: 16rpx; }
.storage-bar-fill { height: 100%; background: var(--csl-gradient); border-radius: 999rpx; }

.anim-fade { opacity: 0; transform: translateY(24rpx); transition: opacity 0.4s ease, transform 0.4s ease; }
.anim-show { opacity: 1; transform: translateY(0); }
.anim-d1 { transition-delay: 0.06s; }
.anim-d2 { transition-delay: 0.12s; }
.anim-d3 { transition-delay: 0.18s; }
.anim-d4 { transition-delay: 0.24s; }
.anim-d5 { transition-delay: 0.30s; }
.press { opacity: 0.7; transform: scale(0.96); }
