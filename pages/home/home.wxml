<!-- pages/home/home.wxml - 极简首页 (ChatGPT 风格) -->
<view class="page">
  <view style="height: {{statusBarHeight}}px;"></view>

  <scroll-view scroll-y class="page-scroll" enhanced show-scrollbar="{{false}}">
    <view class="content">
      <!-- Logo -->
      <view class="logo-area">
        <view class="logo-icon">
          <view class="logo-c"></view>
          <view class="logo-dot"></view>
        </view>
        <text class="logo-title">Cslivem</text>
        <text class="logo-subtitle">你的知识助手</text>
      </view>

      <!-- 输入框 -->
      <view class="input-area">
        <view class="input-box" bindtap="onInputTap">
          <text class="input-placeholder">输入你的想法...</text>
          <view class="input-action">
            <view class="input-plus">+</view>
          </view>
        </view>
      </view>

      <!-- 建议词 -->
      <view class="suggestions">
        <view class="suggestion-chip" bindtap="onSuggestion" data-text="记一下灵感">
          <text class="chip-icon">💡</text>
          <text class="chip-text">记一下灵感</text>
        </view>
        <view class="suggestion-chip" bindtap="onSuggestion" data-text="整理本周笔记">
          <text class="chip-icon">📋</text>
          <text class="chip-text">整理本周笔记</text>
        </view>
        <view class="suggestion-chip" bindtap="onSuggestion" data-text="搜索知识库">
          <text class="chip-icon">🔍</text>
          <text class="chip-text">搜索知识库</text>
        </view>
      </view>
    </view>
  </scroll-view>

  <custom-tabbar selected="{{0}}" />
</view>