<!-- pages/home/home.wxml -->
<view class="page">
  <view style="height: {{statusBarHeight}}px;"></view>

  <scroll-view scroll-y class="page-scroll" enhanced show-scrollbar="{{false}}">
    <view class="content">
      <!-- Logo -->
      <view class="brand-area anim-fade-up {{ready ? 'anim-visible' : ''}}">
        <view class="logo-ring">
          <image
            class="brand-logo"
            src="/assets/icons/cslivem-mark-256.png"
            mode="aspectFit"
          />
          <view class="logo-glow"></view>
        </view>
        <text class="brand-name">Cslivem</text>
        <text class="brand-tagline">今天想了解什么？</text>
      </view>

      <!-- Input Box -->
      <view class="input-wrapper anim-fade-up anim-d1 {{ready ? 'anim-visible' : ''}}">
        <view class="input-box {{inputFocused ? 'input-focused' : ''}}">
          <input
            class="input-field"
            placeholder="输入你的问题..."
            placeholder-class="input-placeholder"
            value="{{inputValue}}"
            bindinput="onInput"
            bindfocus="onFocus"
            bindblur="onBlur"
            bindconfirm="onSend"
            confirm-type="send"
            adjust-position="{{true}}"
            hold-keyboard
          />
          <view
            class="send-btn {{inputValue ? 'send-btn-active' : ''}}"
            bindtap="onSend"
            hover-class="send-btn-hover"
          >
            <text class="send-arrow">→</text>
          </view>
        </view>
      </view>


    <!-- Daily Dashboard -->
    <view class="dashboard anim-fade anim-d1 {{ready ? 'anim-show' : ''}}" wx:if="{{dashboard.habits}}">
      <view class="dash-item" bindtap="onDashTap" data-url="/pages/habit/habit">
        <text class="dash-val">{{dashboard.habits.done}}/{{dashboard.habits.total}}</text>
        <text class="dash-label">习惯</text>
      </view>
      <view class="dash-item" bindtap="onDashTap" data-url="/pages/flashcard/flashcard">
        <text class="dash-val">{{dashboard.flashcards.due}}</text>
        <text class="dash-label">待复习</text>
      </view>
      <view class="dash-item" bindtap="onDashTap" data-url="/pages/mood/mood">
        <text class="dash-val">{{dashboard.mood > 0 ? '☺' : '-'}}</text>
        <text class="dash-label">心情</text>
      </view>
      <view class="dash-item" bindtap="onDashTap" data-url="/pages/food/food">
        <text class="dash-val">{{dashboard.calories}}</text>
        <text class="dash-label">卡路里</text>
      </view>
    </view>

      <!-- Quick Suggestions -->
      <view class="suggestions anim-fade-up anim-d2 {{ready ? 'anim-visible' : ''}}">
        <view
          class="chip"
          wx:for="{{suggestions}}"
          wx:key="text"
          bindtap="onSuggestionTap"
          data-text="{{item.text}}"
          hover-class="chip-press"
        >
          <text class="chip-icon">{{item.icon}}</text>
          <text class="chip-text">{{item.text}}</text>
        </view>
      </view>

      <!-- Recent Conversations -->
      <view class="recent-section anim-fade-up anim-d3 {{ready ? 'anim-visible' : ''}}" wx:if="{{recentConversations.length > 0}}">
        <view class="section-header">
          <text class="section-label">最近对话</text>
        </view>
        <view
          class="recent-item"
          wx:for="{{recentConversations}}"
          wx:key="id"
          bindtap="onConversationTap"
          data-id="{{item.id}}"
          hover-class="recent-press"
        >
          <view class="recent-info">
            <text class="recent-title">{{item.title}}</text>
            <text class="recent-summary" wx:if="{{item.summary}}">{{item.summary}}</text>
          </view>
          <view class="recent-meta">
            <text class="recent-time">{{item.timeAgo}}</text>
            <text class="recent-count">{{item.messageCount}} 条</text>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>

  <custom-tabbar selected="{{0}}" />
</view>
