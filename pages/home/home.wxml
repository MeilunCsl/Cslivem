<!-- pages/home/home.wxml -->
<view class="page">
  <view style="height: {{statusBarHeight}}px;"></view>

  <scroll-view scroll-y class="page-scroll" enhanced show-scrollbar="{{false}}">
    <view class="content">
      <!-- Logo -->
      <view class="brand-area anim-fade-up {{ready ? 'anim-visible' : ''}}">
        <view class="logo-ring">
          <image
            class="brand-logo"
            src="/assets/icons/cslivem-mark-256.png"
            mode="aspectFit"
          />
          <view class="logo-glow"></view>
        </view>
        <text class="brand-name">Cslivem</text>
        <text class="brand-tagline">今天想了解什么？</text>
      </view>

      <!-- 搜索框（点击跳转搜索页） -->
      <view class="input-wrapper anim-fade-up anim-d1 {{ready ? 'anim-visible' : ''}}">
        <view class="input-box" bindtap="onInputTap" hover-class="input-tap-press">
          <text class="input-placeholder-text">输入你的问题...</text>
          <view class="send-btn send-btn-active">
            <text class="send-arrow">→</text>
          </view>
        </view>
      </view>

      <!-- 快捷建议 -->
      <view class="suggestions" wx:if="{{!inputValue}}">
        <view
          class="chip anim-fade-up anim-d{{index + 2}} {{ready ? 'anim-visible' : ''}}"
          wx:for="{{suggestions}}"
          wx:key="text"
          bindtap="onSuggestionTap"
          data-text="{{item.text}}"
          hover-class="chip-press"
        >
          <text class="chip-icon">{{item.icon}}</text>
          <text class="chip-text">{{item.text}}</text>
        </view>
      </view>
    </view>
  </scroll-view>

  <custom-tabbar selected="{{0}}" />
</view>