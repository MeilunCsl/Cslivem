/* pages/home/home.wxss - 首页样式 */

.page {
  height: 100vh;
  background: var(--color-bg, #F7F7FA);
  display: flex;
  flex-direction: column;
}

.page-scroll {
  flex: 1;
  height: 0;
}

.page-container {
  padding: 16rpx 32rpx 40rpx;
}

/* 头部：欢迎语 + 头像 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0 16rpx;
}

.greeting {
  display: flex;
  flex-direction: column;
}

.greeting-text {
  font-size: 28rpx;
  color: var(--color-text-secondary, #74747E);
  margin-bottom: 4rpx;
}

.greeting-name {
  font-size: 44rpx;
  font-weight: 800;
  letter-spacing: -1rpx;
  color: var(--color-text, #17171C);
}

.avatar {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #8577ef, #c4baff);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-text {
  color: #FFFFFF;
  font-weight: 800;
  font-size: 32rpx;
}

/* 搜索区 */
.search-section {
  margin: 24rpx 0;
}

/* 快捷动作 */
.quick-actions {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 18rpx;
  margin-bottom: 32rpx;
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  padding: 20rpx 0;
  background: #FFFFFF;
  border-radius: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(25, 25, 38, 0.04);
}

.action-icon {
  font-size: 44rpx;
  line-height: 1;
}

.action-btn text {
  font-size: 22rpx;
  color: var(--color-text-secondary, #74747E);
}

/* 今日数据卡片 */
.today-cards {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  margin-bottom: 32rpx;
}

.metric-card {
  text-align: center;
  padding: 28rpx 20rpx !important;
}

.metric-value {
  display: block;
  font-size: 48rpx;
  font-weight: 800;
  color: var(--color-text, #17171C);
  margin-bottom: 8rpx;
}

.metric-label {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary, #74747E);
}

/* 区块标题 */
.section {
  margin-bottom: 32rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 800;
  color: var(--color-text, #17171C);
}

.section-action {
  font-size: 26rpx;
  color: var(--color-primary, #6C5CE7);
  font-weight: 600;
}

/* AI 收件箱 */
.inbox-card {
  margin-bottom: 16rpx;
  border-left: 8rpx solid var(--color-warning, #F59E0B);
  padding: 24rpx !important;
}

.inbox-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.inbox-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--color-warning, #F59E0B);
  flex-shrink: 0;
}

.inbox-content {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.inbox-title {
  font-size: 28rpx;
  color: var(--color-text, #17171C);
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.inbox-time {
  font-size: 22rpx;
  color: var(--color-text-secondary, #74747E);
  flex-shrink: 0;
  margin-left: 16rpx;
}

/* 最近笔记横向滚动 */
.notes-scroll {
  white-space: nowrap;
  margin: 0 -32rpx;
  padding: 0 32rpx;
}

.notes-row {
  display: inline-flex;
  gap: 18rpx;
  padding-right: 32rpx;
}

.note-card {
  width: 420rpx;
  display: inline-block;
  white-space: normal;
  vertical-align: top;
  flex-shrink: 0;
  padding: 28rpx !important;
}

.note-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text, #17171C);
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.note-summary {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary, #74747E);
  line-height: 1.5;
  margin-bottom: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  white-space: normal;
}

.note-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.note-time {
  font-size: 22rpx;
  color: var(--color-text-secondary, #74747E);
}

.note-tags {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
  justify-content: flex-end;
}

.tag {
  font-size: 20rpx;
  background: #F1F1F5;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  color: #666666;
}

/* 常用工具网格 */
.tools-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.tool-card {
  min-height: 180rpx;
  display: flex;
  flex-direction: column;
}

.tool-icon {
  font-size: 48rpx;
  margin-bottom: 14rpx;
}

.tool-name {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-text, #17171C);
  margin-bottom: 8rpx;
}

.tool-desc {
  font-size: 22rpx;
  color: var(--color-text-secondary, #74747E);
  line-height: 1.5;
}
