/* pages/home/home.wxss - Cslivem 极简 AI 对话首页 + 动画 */

.page {
  height: 100vh;
  background:
    radial-gradient(
      circle at 50% 42%,
      rgba(226, 232, 255, 0.32),
      rgba(247, 249, 253, 0) 44%
    ),
    #F7F8FB;
  display: flex;
  flex-direction: column;
}

.page-scroll {
  flex: 1;
  height: 0;
}

.content {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 0 var(--csl-page-x, 48rpx);
  padding-bottom: calc(190rpx + env(safe-area-inset-bottom));
}

/* ===== 入场动画系统 ===== */
.anim-fade-up {
  opacity: 0;
  transform: translateY(40rpx);
  transition: opacity 0.6s ease, transform 0.6s var(--ease-spring, cubic-bezier(0.34, 1.56, 0.64, 1));
}

.anim-visible {
  opacity: 1;
  transform: translateY(0);
}

.anim-d1 { transition-delay: 0.1s; }
.anim-d2 { transition-delay: 0.2s; }
.anim-d3 { transition-delay: 0.3s; }
.anim-d4 { transition-delay: 0.4s; }

/* ===== 品牌区域 ===== */
.brand-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.logo-ring {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 32rpx;
}

.brand-logo {
  width: 144rpx;
  height: 144rpx;
  position: absolute;
  top: 8rpx;
  left: 8rpx;
}

.logo-glow {
  position: absolute;
  top: 0;
  left: 0;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(91, 76, 255, 0.15) 0%, transparent 70%);
  animation: pulse-glow 3s ease-in-out infinite;
}

@keyframes pulse-glow {
  0%, 100% { opacity: 0.6; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.15); }
}

.brand-name {
  font-size: 52rpx;
  font-weight: 700;
  color: var(--color-text, #0A0F1A);
  letter-spacing: -0.5rpx;
  margin-bottom: 16rpx;
  font-family: var(--font-family);
}

.brand-tagline {
  font-size: 34rpx;
  color: var(--color-text-secondary, #7B8197);
  font-weight: 400;
}

/* ===== 输入框 ===== */
.input-wrapper {
  width: 100%;
  margin-bottom: 48rpx;
}

.input-box {
  display: flex;
  align-items: center;
  background: var(--color-card, #FFFFFF);
  border-radius: var(--csl-radius-input, 48rpx);
  padding: 12rpx 14rpx 12rpx 36rpx;
  box-shadow: var(--shadow-input, 0 4rpx 24rpx rgba(91, 76, 255, 0.12));
  border: 2rpx solid var(--color-border, #E7EAF0);
  transition: border-color 0.3s ease, box-shadow 0.3s ease;
}

.input-tap-press { transform: scale(0.98); opacity: 0.9; }
.input-focused {
  border-color: var(--color-primary, #5B4CFF);
  box-shadow: 0 4rpx 32rpx rgba(91, 76, 255, 0.2);
}

.input-field {
  flex: 1;
  height: var(--csl-control-height, 104rpx);
  font-size: 30rpx;
  color: var(--color-text, #0A0F1A);
}

.input-placeholder-text {
  flex: 1; font-size: 30rpx; color: var(--color-text-placeholder); line-height: 72rpx;
}
.input-placeholder {
  color: var(--color-text-placeholder, #B0B8C9);
  font-size: 30rpx;
}

.send-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: var(--color-border, #E7EAF0);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.25s var(--ease-spring, ease);
}

.send-btn-active {
  background: var(--csl-gradient, linear-gradient(135deg, #5B4CFF, #3A7BFF, #00D4D9));
  box-shadow: var(--shadow-send, 0 8rpx 32rpx rgba(91, 76, 255, 0.36));
}

.send-btn-hover {
  transform: scale(0.9);
}

.send-arrow {
  font-size: 36rpx;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1;
}

/* ===== 快捷建议 ===== */
.suggestions {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 16rpx;
  max-width: 600rpx;
}

.chip {
  display: flex;
  align-items: center;
  gap: 10rpx;
  background: var(--color-card, #FFFFFF);
  border-radius: var(--radius-full, 999rpx);
  padding: 18rpx 28rpx;
  border: 2rpx solid var(--color-border, #E7EAF0);
  transition: all 0.2s ease;
}

.chip-press {
  transform: scale(0.95);
  border-color: var(--color-primary, #5B4CFF);
  background: var(--color-primary-bg, #EDE9FF);
}

.chip-icon {
  font-size: 28rpx;
  line-height: 1;
}

.chip-text {
  font-size: 26rpx;
  color: var(--color-text-secondary, #7B8197);
}


/* ===== Recent Conversations ===== */
.recent-section {
  width: 100%;
  margin-top: 48rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-label {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-secondary, #7B8197);
}

.recent-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--color-card, #FFFFFF);
  border-radius: var(--radius-lg, 32rpx);
  padding: 24rpx 28rpx;
  margin-bottom: 16rpx;
  border: 2rpx solid var(--color-border, #E7EAF0);
  transition: all 0.2s ease;
}

.recent-press {
  transform: scale(0.98);
  border-color: var(--color-primary, #5B4CFF);
}

.recent-info {
  flex: 1;
  min-width: 0;
}

.recent-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text, #0A0F1A);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 6rpx;
}

.recent-summary {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary, #7B8197);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.recent-meta {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  flex-shrink: 0;
  margin-left: 20rpx;
}

.recent-time {
  font-size: 22rpx;
  color: var(--color-text-placeholder, #B0B8C9);
  margin-bottom: 4rpx;
}

.recent-count {
  font-size: 20rpx;
  color: var(--color-text-placeholder, #B0B8C9);
}

/* Dashboard */
.dashboard {
  display: flex; gap: 12rpx; margin-bottom: 24rpx;
}
.dash-item {
  flex: 1; background: var(--color-card); border-radius: var(--radius-lg);
  padding: 20rpx 12rpx; text-align: center;
  transition: all 0.2s ease;
}
.dash-item:active { transform: scale(0.95); }
.dash-val { display: block; font-size: 32rpx; font-weight: 700; color: var(--color-primary); }
.dash-label { display: block; font-size: 22rpx; color: var(--color-text-secondary); margin-top: 4rpx; }

/* Quick Tools Grid */
.quick-tools { margin-bottom: 32rpx; }
.tools-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20rpx; }
.tool-item { display: flex; flex-direction: column; align-items: center; padding: 24rpx 0; background: var(--color-card); border-radius: 24rpx; }
.tool-icon { font-size: 40rpx; margin-bottom: 8rpx; }
.tool-name { font-size: 22rpx; color: var(--color-text-secondary); }
.tool-press { opacity: 0.7; transform: scale(0.95); }
