/* pages/home/home.wxss - ChatGPT 极简风格 */

.page {
  height: 100vh;
  background: #F7F7FA;
  display: flex;
  flex-direction: column;
}

.page-scroll {
  flex: 1;
  height: 0;
}

.content {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 0 48rpx;
  padding-bottom: 180rpx;
}

/* ===== Logo 区域 ===== */
.logo-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 64rpx;
}

.logo-icon {
  width: 140rpx;
  height: 140rpx;
  position: relative;
  margin-bottom: 32rpx;
}

.logo-c {
  width: 140rpx;
  height: 140rpx;
  border-radius: 42rpx;
  background: linear-gradient(135deg, #6C5CE7 0%, #A29BFE 100%);
  position: relative;
  overflow: hidden;
}

.logo-c::after {
  content: '';
  position: absolute;
  right: 12rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #F7F7FA;
}

.logo-dot {
  position: absolute;
  right: 0;
  bottom: 8rpx;
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #6C5CE7, #A29BFE);
  border: 6rpx solid #F7F7FA;
}

.logo-title {
  font-size: 52rpx;
  font-weight: 800;
  color: #17171C;
  letter-spacing: -1rpx;
  margin-bottom: 12rpx;
}

.logo-subtitle {
  font-size: 30rpx;
  color: #74747E;
}

/* ===== 输入框 ===== */
.input-area {
  width: 100%;
  margin-bottom: 48rpx;
}

.input-box {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 36rpx;
  padding: 28rpx 20rpx 28rpx 36rpx;
  box-shadow: 0 8rpx 40rpx rgba(25, 25, 38, 0.06);
  border: 2rpx solid rgba(0, 0, 0, 0.04);
}

.input-placeholder {
  flex: 1;
  font-size: 30rpx;
  color: #B4B4BE;
}

.input-action {
  flex-shrink: 0;
}

.input-plus {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #6C5CE7;
  color: #FFFFFF;
  font-size: 40rpx;
  font-weight: 300;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ===== 建议词 ===== */
.suggestions {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 16rpx;
}

.suggestion-chip {
  display: flex;
  align-items: center;
  gap: 10rpx;
  background: #FFFFFF;
  border-radius: 999rpx;
  padding: 18rpx 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(25, 25, 38, 0.04);
  border: 2rpx solid rgba(0, 0, 0, 0.04);
}

.chip-icon {
  font-size: 28rpx;
}

.chip-text {
  font-size: 26rpx;
  color: #555555;
}