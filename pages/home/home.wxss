/* pages/home/home.wxss - Cslivem 极简 AI 对话首页 */

.page {
  height: 100vh;
  background: var(--color-bg, #F2F4F8);
  display: flex;
  flex-direction: column;
}

.page-scroll {
  flex: 1;
  height: 0;
}

.content {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 0 var(--csl-page-x, 48rpx);
  /* 底部 TabBar 遮挡 + 安全区 */
  padding-bottom: calc(200rpx + env(safe-area-inset-bottom));
}

/* ===== 品牌区域 ===== */
.brand-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.brand-logo {
  width: 144rpx;
  height: 144rpx;
  margin-bottom: 28rpx;
}

.brand-name {
  font-size: 52rpx;
  font-weight: 700;
  color: var(--color-text, #0A0F1A);
  letter-spacing: -0.5rpx;
  margin-bottom: 16rpx;
  font-family: var(--font-family);
}

.brand-tagline {
  font-size: 34rpx;
  color: var(--color-text-secondary, #7B8197);
  font-weight: 400;
}

/* ===== 输入框 ===== */
.input-wrapper {
  width: 100%;
  margin-bottom: 48rpx;
}

.input-box {
  display: flex;
  align-items: center;
  background: var(--color-card, #FFFFFF);
  border-radius: var(--csl-radius-input, 96rpx);
  padding: 12rpx 14rpx 12rpx 36rpx;
  box-shadow: var(--shadow-input, 0 4rpx 24rpx rgba(91, 76, 255, 0.12));
  border: 2rpx solid var(--color-border, #E7EAF0);
  transition: border-color 0.2s ease, box-shadow 0.2s ease;
}

.input-field {
  flex: 1;
  height: var(--csl-control-height, 104rpx);
  font-size: 30rpx;
  color: var(--color-text, #0A0F1A);
}

.input-placeholder {
  color: var(--color-text-placeholder, #B0B8C9);
  font-size: 30rpx;
}

.send-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: var(--color-border, #E7EAF0);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.25s var(--ease-spring, ease);
}

.send-btn-active {
  background: var(--csl-gradient, linear-gradient(135deg, #5B4CFF, #3A7BFF, #00D4D9));
  box-shadow: var(--shadow-send, 0 8rpx 32rpx rgba(91, 76, 255, 0.36));
}

.send-arrow {
  font-size: 36rpx;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1;
}

/* ===== 快捷建议 ===== */
.suggestions {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 16rpx;
  max-width: 600rpx;
}

.chip {
  display: flex;
  align-items: center;
  gap: 10rpx;
  background: var(--color-card, #FFFFFF);
  border-radius: var(--radius-full, 999rpx);
  padding: 18rpx 28rpx;
  border: 2rpx solid var(--color-border, #E7EAF0);
  transition: all 0.2s ease;
}

.chip:active {
  transform: scale(0.96);
  border-color: var(--color-primary, #5B4CFF);
}

.chip-icon {
  font-size: 28rpx;
  line-height: 1;
}

.chip-text {
  font-size: 26rpx;
  color: var(--color-text-secondary, #7B8197);
}