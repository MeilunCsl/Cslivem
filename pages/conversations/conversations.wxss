/* pages/conversations/conversations.wxss */
.page { height: 100vh; background: var(--color-bg); display: flex; flex-direction: column; }
.page-scroll { flex: 1; height: 0; }
.page-container { padding: 16rpx var(--csl-page-x) 240rpx; }

.header { padding: 24rpx 0 8rpx; }
.page-title { font-size: var(--font-size-title-lg); font-weight: 700; color: var(--color-text); display: block; }
.page-sub { font-size: 24rpx; color: var(--color-text-secondary); margin-top: 4rpx; display: block; }
.search-section { margin: 16rpx 0; }
.search-box { display: flex; align-items: center; background: var(--color-card); border-radius: var(--radius-full); padding: 0 28rpx; height: 80rpx; box-shadow: var(--shadow-card); }
.search-icon { font-size: 28rpx; margin-right: 16rpx; }
.search-field { flex: 1; font-size: 28rpx; color: var(--color-text); }
.clear-btn { font-size: 28rpx; color: var(--color-text-secondary); padding: 8rpx; }

.filters-scroll { white-space: nowrap; margin: 8rpx -48rpx; padding: 0 48rpx; }
.filters-row { display: inline-flex; gap: 16rpx; padding-right: 48rpx; }
.filter { display: inline-flex; align-items: center; padding: 14rpx 28rpx; border-radius: var(--radius-full); font-size: 26rpx; background: var(--color-card); color: var(--color-text-secondary); white-space: nowrap; border: 2rpx solid transparent; transition: all 0.2s ease; }
.filter.active { background: var(--color-primary); color: #FFFFFF; }
.filter-press { transform: scale(0.95); opacity: 0.8; }

.conv-list { margin-top: 20rpx; }
.conv-item { margin-bottom: 16rpx; transition: transform 0.2s ease; }
.conv-press { transform: scale(0.98); }
.conv-header { display: flex; align-items: center; gap: 16rpx; }
.conv-icon { font-size: 36rpx; flex-shrink: 0; }
.conv-info { flex: 1; min-width: 0; }
.conv-title { display: block; font-size: 30rpx; font-weight: 600; color: var(--color-text); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.conv-meta { display: block; font-size: 22rpx; color: var(--color-text-secondary); margin-top: 4rpx; }
.conv-actions { display: flex; gap: 16rpx; flex-shrink: 0; }
.conv-pin, .conv-delete { font-size: 28rpx; padding: 8rpx; }
.conv-summary { display: block; font-size: 24rpx; color: var(--color-text-secondary); margin-top: 10rpx; overflow: hidden; text-overflow: ellipsis; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; }
.conv-footer { display: flex; justify-content: space-between; align-items: center; margin-top: 12rpx; }
.conv-status { font-size: 20rpx; color: var(--color-text-placeholder); padding: 4rpx 14rpx; background: var(--csl-surface-muted); border-radius: var(--radius-full); }
.status-ingested { background: rgba(36, 161, 72, 0.1); color: var(--color-success); }
.conv-model { font-size: 20rpx; color: var(--color-text-placeholder); }

.empty { display: flex; flex-direction: column; align-items: center; padding: 120rpx 0; }
.empty-icon { font-size: 80rpx; margin-bottom: 20rpx; opacity: 0.3; }
.empty-text { font-size: 30rpx; color: var(--color-text-secondary); margin-bottom: 12rpx; }
.empty-hint { font-size: 24rpx; color: var(--color-text-placeholder); }

.fab-create { position: fixed; right: 40rpx; bottom: calc(190rpx + env(safe-area-inset-bottom)); width: 96rpx; height: 96rpx; border-radius: 50%; background: linear-gradient(135deg, #5B4CFF 0%, #3A7BFF 52%, #00D4D9 100%); display: flex; align-items: center; justify-content: center; box-shadow: 0 8rpx 24rpx rgba(91, 76, 255, 0.3); z-index: 90; transition: transform 0.2s ease; }
.fab-press { transform: scale(0.92); }
.fab-icon { font-size: 48rpx; color: #FFF; font-weight: 300; }
