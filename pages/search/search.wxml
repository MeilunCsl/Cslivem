<!-- pages/search/search.wxml -->
<view class="page">
  <view style="height: {{statusBarHeight}}px;"></view>
  <view class="search-bar anim-fade {{ready ? 'anim-show' : ''}}">
    <view class="back-btn" bindtap="onBack" hover-class="btn-press">←</view>
    <view class="search-wrap">
      <input
        class="search-input"
        placeholder="搜索笔记、事件、流水..."
        value="{{query}}"
        bindinput="onInput"
        bindconfirm="onSearch"
        focus="{{true}}"
        confirm-type="search"
      />
      <view class="clear-btn" wx:if="{{query}}" bindtap="onClear">×</view>
    </view>
    <view class="go-btn" bindtap="onSearch" hover-class="btn-press">搜索</view>
  </view>

  <scroll-view scroll-y class="result-scroll" enhanced show-scrollbar="{{false}}">
    <!-- Hot Keys -->
    <view class="hot-keys anim-fade anim-d1 {{ready ? 'anim-show' : ''}}" wx:if="{{!searched}}">
      <text class="hot-title">热门搜索</text>
      <view class="hot-list">
        <view class="hot-item" wx:for="{{hotKeys}}" wx:key="*this" bindtap="onHotKey" data-key="{{item}}" hover-class="hot-press">
          {{item}}
        </view>
      </view>
    </view>

    <!-- Results -->
    <view class="results anim-fade anim-d1 {{ready ? 'anim-show' : ''}}" wx:if="{{searched}}">
      <view class="result-count" wx:if="{{results.length > 0}}">
        找到 {{results.length}} 条结果
      </view>
      <view class="empty-search" wx:if="{{results.length === 0}}">
        <text class="empty-icon">🔍</text>
        <text class="empty-text">未找到相关内容</text>
      </view>
      <card className="result-card" wx:for="{{results}}" wx:key="id" bindtap="onResultTap" data-url="{{item.url}}" hover-class="result-press">
        <view class="result-item">
          <text class="result-icon">{{item.icon}}</text>
          <view class="result-info">
            <text class="result-title">{{item.title}}</text>
            <text class="result-subtitle">{{item.subtitle}}</text>
          </view>
          <text class="result-type">{{item.type}}</text>
        </view>
      </card>
    </view>
  </scroll-view>
</view>
