/* pages/scanner/scanner.wxss */
.page { height: 100vh; background: var(--color-bg); display: flex; flex-direction: column; }
.nav-bar { display: flex; align-items: center; height: 88rpx; padding: 0 24rpx; background: var(--color-card); border-bottom: 1rpx solid var(--color-divider); }
.nav-back { font-size: 48rpx; color: var(--color-primary); padding: 0 16rpx; }
.nav-title { flex: 1; text-align: center; font-size: 32rpx; font-weight: 600; color: var(--color-text); }
.content { flex: 1; padding: 32rpx var(--csl-page-x); }
.section { margin-bottom: 32rpx; }
.empty-state { display: flex; flex-direction: column; align-items: center; padding: 80rpx 0 40rpx; }
.empty-icon { font-size: 96rpx; margin-bottom: 24rpx; color: var(--color-text-secondary); }
.empty-text { font-size: 32rpx; font-weight: 600; color: var(--color-text); margin-bottom: 12rpx; }
.empty-hint { font-size: 26rpx; color: var(--color-text-secondary); }
.source-section { display: flex; gap: 24rpx; justify-content: center; padding: 32rpx 0; }
.source-btn { display: flex; flex-direction: column; align-items: center; gap: 16rpx; padding: 48rpx 64rpx; background: var(--color-card); border-radius: var(--radius-lg); border: 2rpx solid var(--color-border); transition: all 0.2s ease; }
.source-press { transform: scale(0.96); border-color: var(--color-primary); }
.source-icon { font-size: 64rpx; color: var(--color-primary); }
.source-text { font-size: 28rpx; color: var(--color-text); font-weight: 500; }
.preview-wrap { border-radius: var(--radius-lg); overflow: hidden; background: var(--color-card); }
.preview-image { width: 100%; }
.settings-toggle { display: flex; justify-content: space-between; align-items: center; padding: 20rpx 24rpx; background: var(--color-card); border-radius: var(--radius-lg); margin-bottom: 16rpx; }
.toggle-arrow { color: var(--color-text-secondary); font-size: 24rpx; }
.settings-panel { background: var(--color-card); border-radius: var(--radius-lg); padding: 24rpx; }
.setting-row { display: flex; align-items: center; gap: 16rpx; padding: 16rpx 0; }
.setting-label { font-size: 28rpx; color: var(--color-text); width: 120rpx; flex-shrink: 0; }
.enhance-btn { height: 88rpx; display: flex; align-items: center; justify-content: center; background: var(--csl-gradient); border-radius: var(--radius-lg); color: #FFF; font-size: 30rpx; font-weight: 600; margin-bottom: 16rpx; }
.btn-press { opacity: 0.8; }
.action-row { display: flex; gap: 16rpx; margin-bottom: 16rpx; }
.action-btn { flex: 1; height: 80rpx; display: flex; align-items: center; justify-content: center; background: var(--color-card); border-radius: var(--radius-lg); font-size: 28rpx; color: var(--color-text); border: 2rpx solid var(--color-border); }
.reset-link { text-align: center; padding: 24rpx; color: var(--color-primary); font-size: 28rpx; }
.loading-section { display: flex; flex-direction: column; align-items: center; padding: 80rpx 0; gap: 24rpx; }
.loading-dots { display: flex; gap: 8rpx; }
.dot { width: 12rpx; height: 12rpx; border-radius: 50%; background: var(--color-primary); animation: bounce 1.4s ease-in-out infinite; }
.dot1 { animation-delay: 0s; }
.dot2 { animation-delay: 0.2s; }
.dot3 { animation-delay: 0.4s; }
@keyframes bounce { 0%, 80%, 100% { transform: translateY(0); opacity: 0.4; } 40% { transform: translateY(-12rpx); opacity: 1; } }
.loading-text { font-size: 28rpx; color: var(--color-text-secondary); }
