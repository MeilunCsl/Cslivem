/* pages/food/food.wxss */
.page { height: 100vh; background: var(--color-bg); display: flex; flex-direction: column; }
.nav-bar { display: flex; align-items: center; height: 88rpx; padding: 0 24rpx; background: var(--color-card); border-bottom: 1rpx solid var(--color-divider); }
.nav-back { font-size: 48rpx; color: var(--color-primary); padding: 0 16rpx; }
.nav-title { flex: 1; text-align: center; font-size: 32rpx; font-weight: 600; color: var(--color-text); }
.content { flex: 1; padding: 24rpx var(--csl-page-x); }
.summary-card { background: var(--csl-gradient); border-radius: var(--radius-xl); padding: 32rpx; margin-bottom: 16rpx; }
.summary-main { text-align: center; margin-bottom: 24rpx; }
.summary-cal { font-size: 72rpx; font-weight: 700; color: #FFF; }
.summary-unit { font-size: 26rpx; color: rgba(255,255,255,0.8); margin-left: 8rpx; }
.summary-meals { display: flex; }
.meal-stat { flex: 1; text-align: center; }
.meal-val { display: block; font-size: 32rpx; font-weight: 600; color: #FFF; }
.meal-label { display: block; font-size: 22rpx; color: rgba(255,255,255,0.7); }
.week-bar { padding: 12rpx 24rpx; background: var(--color-card); border-radius: var(--radius-md); margin-bottom: 16rpx; }
.week-text { font-size: 24rpx; color: var(--color-text-secondary); }
.meal-selector { display: flex; gap: 8rpx; margin-bottom: 20rpx; }
.meal-tab { flex: 1; text-align: center; padding: 16rpx 0; background: var(--color-card); border-radius: var(--radius-md); font-size: 26rpx; color: var(--color-text-secondary); }
.meal-active { background: var(--color-primary); color: #FFF; font-weight: 600; }
.section { margin-bottom: 20rpx; }
.section-title { font-size: 28rpx; font-weight: 600; color: var(--color-text); margin-bottom: 12rpx; display: block; }
.preset-grid { display: flex; flex-wrap: wrap; gap: 12rpx; }
.preset-item { padding: 16rpx 24rpx; background: var(--color-card); border-radius: var(--radius-md); border: 1rpx solid var(--color-border); text-align: center; min-width: 140rpx; }
.preset-press { transform: scale(0.95); border-color: var(--color-primary); }
.preset-name { display: block; font-size: 26rpx; color: var(--color-text); font-weight: 500; }
.preset-cal { display: block; font-size: 22rpx; color: var(--color-text-secondary); margin-top: 4rpx; }
.add-btn { height: 72rpx; display: flex; align-items: center; justify-content: center; background: var(--color-card); border-radius: var(--radius-md); border: 2rpx dashed var(--color-border); color: var(--color-primary); font-size: 26rpx; margin-bottom: 16rpx; }
.btn-press { opacity: 0.7; }
.add-form { background: var(--color-card); border-radius: var(--radius-lg); padding: 24rpx; margin-bottom: 20rpx; }
.form-input { height: 72rpx; background: var(--csl-surface-muted); border-radius: var(--radius-md); padding: 0 24rpx; font-size: 26rpx; margin-bottom: 12rpx; }
.submit-btn { height: 72rpx; display: flex; align-items: center; justify-content: center; background: var(--csl-gradient); border-radius: var(--radius-md); color: #FFF; font-size: 28rpx; font-weight: 600; }
.record-item { display: flex; align-items: center; gap: 12rpx; padding: 16rpx 20rpx; background: var(--color-card); border-radius: var(--radius-md); margin-bottom: 8rpx; }
.record-info { flex: 1; }
.record-name { display: block; font-size: 28rpx; color: var(--color-text); font-weight: 500; }
.record-time { display: block; font-size: 22rpx; color: var(--color-text-secondary); }
.record-cal { font-size: 28rpx; font-weight: 600; color: var(--color-primary); min-width: 80rpx; text-align: right; }
.record-del { padding: 8rpx; font-size: 24rpx; color: var(--color-text-secondary); }
