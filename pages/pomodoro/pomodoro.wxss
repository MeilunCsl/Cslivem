/* pages/pomodoro/pomodoro.wxss */
.page { height: 100vh; background: var(--color-bg); display: flex; flex-direction: column; }
.nav-bar { display: flex; align-items: center; height: 88rpx; padding: 0 24rpx; background: var(--color-card); border-bottom: 1rpx solid var(--color-divider); }
.nav-back { font-size: 48rpx; color: var(--color-primary); padding: 0 16rpx; }
.nav-title { flex: 1; text-align: center; font-size: 32rpx; font-weight: 600; color: var(--color-text); }

.timer-area { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 40rpx var(--csl-page-x); }

.mode-indicator { display: flex; gap: 24rpx; margin-bottom: 48rpx; }
.mode-label { font-size: 26rpx; color: var(--color-text-secondary); padding: 8rpx 24rpx; border-radius: var(--radius-full); }
.mode-active { background: var(--color-primary); color: #FFF; font-weight: 600; }

.timer-circle { width: 420rpx; height: 420rpx; margin-bottom: 48rpx; }
.timer-progress { width: 100%; height: 100%; border-radius: 50%; display: flex; align-items: center; justify-content: center; }
.timer-inner { width: 360rpx; height: 360rpx; border-radius: 50%; background: var(--color-card); display: flex; flex-direction: column; align-items: center; justify-content: center; }
.timer-display { font-size: 80rpx; font-weight: 300; color: var(--color-text); letter-spacing: 4rpx; }
.timer-status { font-size: 24rpx; color: var(--color-text-secondary); margin-top: 8rpx; }

.controls { display: flex; align-items: center; gap: 40rpx; margin-bottom: 32rpx; }
.ctrl-btn { display: flex; align-items: center; justify-content: center; border-radius: 50%; transition: all 0.2s ease; }
.ctrl-press { transform: scale(0.9); }
.ctrl-reset { width: 72rpx; height: 72rpx; background: var(--color-card); border: 2rpx solid var(--color-border); font-size: 32rpx; color: var(--color-text-secondary); }
.ctrl-main { width: 100rpx; height: 100rpx; font-size: 40rpx; color: #FFF; }
.ctrl-start { background: var(--csl-gradient); }
.ctrl-pause { background: var(--color-warning); }
.ctrl-skip { width: 72rpx; height: 72rpx; background: var(--color-card); border: 2rpx solid var(--color-border); font-size: 28rpx; color: var(--color-text-secondary); }

.session-counter { font-size: 26rpx; color: var(--color-text-secondary); margin-bottom: 32rpx; }

.stats-bar { display: flex; gap: 24rpx; width: 100%; }
.stat-item { flex: 1; background: var(--color-card); border-radius: var(--radius-lg); padding: 20rpx; text-align: center; }
.stat-value { display: block; font-size: 36rpx; font-weight: 700; color: var(--color-primary); }
.stat-label { display: block; font-size: 22rpx; color: var(--color-text-secondary); margin-top: 4rpx; }
