<!-- pages/ai-chat/ai-chat.wxml -->
<view class="page">
  <view style="height: {{statusBarHeight}}px;"></view>

  <!-- Header -->
  <view class="header anim-fade {{ready ? 'anim-show' : ''}}">
    <view class="back-btn" bindtap="onBack" hover-class="btn-press">\u2190</view>
    <text class="header-title">Cslivem AI</text>
    <view class="clear-btn" bindtap="onClear" hover-class="btn-press">\u6e05\u7a7a</view>
  </view>

  <!-- Messages -->
  <scroll-view scroll-y class="chat-scroll" enhanced show-scrollbar="{{false}}" scroll-into-view="{{scrollIntoView}}">
    <view class="chat-container">
      <!-- Welcome -->
      <view class="welcome anim-fade anim-d1 {{ready ? 'anim-show' : ''}}" wx:if="{{messages.length === 0}}">
        <view class="welcome-icon-wrap">
          <image class="welcome-logo" src="/assets/icons/cslivem-mark-256.png" mode="aspectFit" />
        </view>
        <text class="welcome-title">Cslivem AI \u52a9\u624b</text>
        <text class="welcome-desc">\u6709\u4ec0\u4e48\u53ef\u4ee5\u5e2e\u4f60\u7684\uff1f</text>

        <!-- Quick Suggestions -->
        <view class="welcome-suggestions">
          <view
            class="welcome-chip"
            wx:for="{{suggestions}}"
            wx:key="text"
            bindtap="onSuggestionTap"
            data-text="{{item.text}}"
            hover-class="chip-press"
          >
            <text class="welcome-chip-text">{{item.text}}</text>
          </view>
        </view>
      </view>

      <!-- Message Bubbles -->
      <view
        id="msg-{{index}}"
        class="msg-row {{item.role === 'user' ? 'msg-user' : 'msg-ai'}}"
        wx:for="{{messages}}"
        wx:key="index"
      >
        <view class="msg-bubble {{item.role}}">
          <text class="msg-content">{{item.content}}</text>
          <view class="msg-footer">
            <text class="msg-meta">{{item.time}} {{item.mode === 'local' ? '\ud83d\udce1' : ''}}</text>
            <view
              class="msg-save-btn"
              wx:if="{{item.role === 'assistant' && item.canSave}}"
              bindtap="onSaveAsNote"
              data-content="{{item.content}}"
              hover-class="btn-press"
            >
              <text class="msg-save-text">\ud83d\udcbe \u4fdd\u5b58</text>
            </view>
          </view>
        </view>
      </view>

      <!-- Typing Indicator -->
      <view class="msg-row msg-ai" wx:if="{{isTyping}}">
        <view class="msg-bubble assistant typing-bubble">
          <view class="typing-indicator">
            <view class="typing-dot"></view>
            <view class="typing-dot"></view>
            <view class="typing-dot"></view>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>

  <!-- Input Bar -->
  <view class="input-bar">
    <input
      class="chat-input"
      placeholder="\u8f93\u5165\u4f60\u7684\u95ee\u9898..."
      value="{{inputValue}}"
      bindinput="onInput"
      bindconfirm="onSend"
      confirm-type="send"
      adjust-position="{{true}}"
      hold-keyboard
    />
    <view
      class="send-btn {{inputValue ? 'active' : ''}}"
      bindtap="onSend"
      hover-class="send-press"
    >
      <text class="send-icon">\u2192</text>
    </view>
  </view>
</view>
