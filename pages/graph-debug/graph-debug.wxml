<!-- pages/graph-debug/graph-debug.wxml -->
<view class="page">
  <view style="height:{{statusBarHeight}}px;"></view>
  <view class="header">
    <view class="back" bindtap="onBack">←</view>
    <text class="title">Graph Debug</text>
  </view>
  <scroll-view scroll-y class="body">
    <view class="stats">
      <text>Nodes: {{stats.nodeCount}} | Edges: {{stats.edgeCount}} | Version: {{stats.version}}</text>
    </view>
    <view class="btns">
      <view class="btn" bindtap="addTestNode" hover-class="press">+ Node</view>
      <view class="btn" bindtap="addTestEdge" hover-class="press">+ Edge</view>
      <view class="btn" bindtap="testNeighbors" hover-class="press">Neighbors</view>
      <view class="btn" bindtap="testSearch" hover-class="press">Search</view>
      <view class="btn" bindtap="testTraverse" hover-class="press">Traverse</view>
      <view class="btn" bindtap="exportGraph" hover-class="press">Export JSON</view>
      <view class="btn danger" bindtap="clearGraph" hover-class="press">Clear All</view>
    </view>
    <view class="log">
      <text class="log-title">Log:</text>
      <text class="log-line" wx:for="{{log}}" wx:key="index">{{item}}</text>
    </view>
  </scroll-view>
</view>
