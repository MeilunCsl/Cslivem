.page{height:100vh;background:#f5f5f5;display:flex;flex-direction:column}
.header{display:flex;align-items:center;gap:16rpx;padding:16rpx 32rpx;background:#fff}
.back{font-size:36rpx;color:#5B4CFF;padding:8rpx}
.title{font-size:32rpx;font-weight:700}
.body{flex:1;height:0;padding:24rpx 32rpx}
.stats{background:#fff;padding:20rpx 24rpx;border-radius:16rpx;margin-bottom:24rpx;font-size:26rpx}
.btns{display:flex;flex-wrap:wrap;gap:16rpx;margin-bottom:24rpx}
.btn{padding:16rpx 28rpx;background:#5B4CFF;color:#fff;border-radius:12rpx;font-size:26rpx}
.btn.danger{background:#DC3545}
.press{transform:scale(0.94);opacity:0.8}
.log{background:#fff;padding:20rpx 24rpx;border-radius:16rpx}
.log-title{font-size:26rpx;font-weight:700;display:block;margin-bottom:12rpx}
.log-line{font-size:22rpx;color:#555;display:block;margin-bottom:4rpx;font-family:monospace}
