/* pages/mood/mood.wxss */
.page { height: 100vh; background: var(--color-bg); display: flex; flex-direction: column; }
.nav-bar { display: flex; align-items: center; height: 88rpx; padding: 0 24rpx; background: var(--color-card); border-bottom: 1rpx solid var(--color-divider); }
.nav-back { font-size: 48rpx; color: var(--color-primary); padding: 0 16rpx; }
.nav-title { flex: 1; text-align: center; font-size: 32rpx; font-weight: 600; color: var(--color-text); }
.content { flex: 1; padding: 24rpx var(--csl-page-x); }

.section-title { font-size: 30rpx; font-weight: 600; color: var(--color-text); margin-bottom: 16rpx; display: block; }

.today-section { background: var(--color-card); border-radius: var(--radius-lg); padding: 24rpx; margin-bottom: 20rpx; }
.mood-selector { display: flex; justify-content: space-around; margin-bottom: 20rpx; }
.mood-opt { display: flex; flex-direction: column; align-items: center; gap: 8rpx; padding: 16rpx; border-radius: var(--radius-md); transition: all 0.2s ease; }
.mood-sel { background: var(--color-primary-bg); transform: scale(1.1); }
.mood-icon { font-size: 48rpx; }
.mood-label { font-size: 22rpx; color: var(--color-text-secondary); }
.note-input { width: 100%; min-height: 80rpx; background: var(--csl-surface-muted); border-radius: var(--radius-md); padding: 16rpx; font-size: 26rpx; margin-bottom: 16rpx; box-sizing: border-box; }
.save-btn { height: 72rpx; display: flex; align-items: center; justify-content: center; background: var(--csl-gradient); border-radius: var(--radius-md); color: #FFF; font-size: 28rpx; font-weight: 600; }
.btn-press { opacity: 0.7; }

.stats-section { display: flex; gap: 16rpx; margin-bottom: 20rpx; }
.stat-item { flex: 1; background: var(--color-card); border-radius: var(--radius-lg); padding: 20rpx; text-align: center; }
.stat-val { display: block; font-size: 36rpx; font-weight: 700; color: var(--color-primary); }
.stat-lbl { display: block; font-size: 22rpx; color: var(--color-text-secondary); margin-top: 4rpx; }

.recent-section { background: var(--color-card); border-radius: var(--radius-lg); padding: 24rpx; }
.recent-item { display: flex; align-items: center; gap: 16rpx; padding: 12rpx 0; border-bottom: 1rpx solid var(--color-divider); }
.recent-item:last-child { border-bottom: none; }
.recent-date { font-size: 24rpx; color: var(--color-text-secondary); width: 160rpx; }
.recent-mood { font-size: 32rpx; width: 48rpx; text-align: center; }
.recent-note { flex: 1; font-size: 26rpx; color: var(--color-text); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
