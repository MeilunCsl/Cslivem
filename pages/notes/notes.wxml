<!-- pages/notes/notes.wxml -->
<view class="page">
  <view style="height: {{statusBarHeight}}px;"></view>
  <scroll-view scroll-y class="page-scroll" enhanced show-scrollbar="{{false}}">
    <view class="page-container">
      <view class="header anim-fade {{ready ? 'anim-show' : ''}}">
        <text class="page-title">知识</text>
      </view>

      <view class="search-section anim-fade anim-d1 {{ready ? 'anim-show' : ''}}">
        <search-input placeholder="搜索笔记..." showAi="{{false}}" />
      </view>

      <scroll-view scroll-x class="filters-scroll anim-fade anim-d2 {{ready ? 'anim-show' : ''}}" enhanced show-scrollbar="{{false}}">
        <view class="filters-row">
          <view class="filter {{activeFilter === item.key ? 'active' : ''}}" wx:for="{{filters}}" wx:key="key" bindtap="setFilter" data-filter="{{item.key}}" hover-class="filter-press">
            {{item.label}}
            <text class="filter-badge" wx:if="{{item.key === 'inbox' && inboxCount > 0}}">{{inboxCount}}</text>
          </view>
        </view>
      </scroll-view>

      <view class="note-list">
        <card className="note-item anim-fade anim-d{{index < 4 ? index + 2 : 5}} {{ready ? 'anim-show' : ''}}" wx:for="{{notes}}" wx:key="id" hover-class="note-press" bindtap="onTapNote" data-id="{{item.id}}">
          <text class="note-item-title">{{item.title}}</text>
          <text class="note-item-summary">{{item.summary || item.content}}</text>
          <view class="note-item-footer">
            <text class="note-item-time">{{item.timeAgo}}</text>
            <view class="note-item-tags">
              <text class="tag" wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this">{{tag}}</text>
            </view>
          </view>
        </card>
      </view>

      <view class="empty anim-fade {{ready ? 'anim-show' : ''}}" wx:if="{{notes.length === 0}}">
        <text class="empty-icon">📝</text>
        <text class="empty-text">还没有笔记</text>
        <text class="empty-hint">点击右下角 + 开始记录</text>
      </view>
    </view>
  </scroll-view>

  </view>
  <view class="fab-create" bindtap="createNote" hover-class="fab-press">
    <text class="fab-icon">+</text>
  </view>

  <custom-tabbar selected="{{2}}" />
</view>