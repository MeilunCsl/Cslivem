/* pages/notes/notes.wxss */
.page { height: 100vh; background: var(--color-bg); display: flex; flex-direction: column; }
.page-scroll { flex: 1; height: 0; }
.page-container { padding: 16rpx var(--csl-page-x) 240rpx; }
.header { padding: 24rpx 0 8rpx; }
.page-title { font-size: var(--font-size-title-lg); font-weight: 700; color: var(--color-text); }
.search-section { margin: 16rpx 0; }

.anim-fade { opacity: 0; transform: translateY(24rpx); transition: opacity 0.5s ease, transform 0.5s var(--ease-spring); }
.anim-show { opacity: 1; transform: translateY(0); }
.anim-d1 { transition-delay: 0.08s; }
.anim-d2 { transition-delay: 0.16s; }
.anim-d3 { transition-delay: 0.24s; }
.anim-d4 { transition-delay: 0.32s; }
.anim-d5 { transition-delay: 0.4s; }

.filters-scroll { white-space: nowrap; margin: 8rpx -48rpx; padding: 0 48rpx; }
.filters-row { display: inline-flex; gap: 16rpx; padding-right: 48rpx; }
.filter { display: inline-flex; align-items: center; gap: 8rpx; padding: 14rpx 28rpx; border-radius: var(--radius-full); font-size: 26rpx; background: var(--color-card); color: var(--color-text-secondary); white-space: nowrap; border: 2rpx solid transparent; transition: all 0.2s ease; }
.filter.active { background: var(--color-primary); color: #FFFFFF; }
.filter-press { transform: scale(0.95); opacity: 0.8; }
.filter-badge { font-size: 20rpx; background: var(--color-warning); color: #FFF; padding: 2rpx 12rpx; border-radius: var(--radius-full); min-width: 32rpx; text-align: center; }

.note-list { margin-top: 20rpx; }
.note-item { margin-bottom: 16rpx; transition: transform 0.2s ease; }
.note-press { transform: scale(0.98); }
.note-item-title { display: block; font-size: 30rpx; font-weight: 600; color: var(--color-text); margin-bottom: 10rpx; }
.note-item-summary { display: block; font-size: 24rpx; color: var(--color-text-secondary); line-height: 1.5; margin-bottom: 14rpx; overflow: hidden; text-overflow: ellipsis; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; }
.note-item-footer { display: flex; justify-content: space-between; align-items: center; }
.note-item-time { font-size: 22rpx; color: var(--color-text-secondary); }
.note-item-tags { display: flex; gap: 8rpx; }
.tag { font-size: 20rpx; background: var(--csl-surface-muted); padding: 4rpx 14rpx; border-radius: var(--radius-full); color: var(--color-text-secondary); }

.empty { display: flex; flex-direction: column; align-items: center; padding: 120rpx 0; }
.empty-icon { font-size: 80rpx; margin-bottom: 20rpx; opacity: 0.3; }
.empty-text { font-size: 30rpx; color: var(--color-text-secondary); margin-bottom: 12rpx; }
.empty-hint { font-size: 24rpx; color: var(--color-text-placeholder); }

.fab-create { position: fixed; right: 40rpx; bottom: calc(190rpx + env(safe-area-inset-bottom)); width: 96rpx; height: 96rpx; border-radius: 50%; background: var(--csl-gradient); display: flex; align-items: center; justify-content: center; box-shadow: var(--shadow-fab); z-index: 90; transition: transform 0.2s ease, box-shadow 0.2s ease; }
.fab-press { transform: scale(0.92); box-shadow: 0 4rpx 12rpx rgba(91, 76, 255, 0.2); }
.fab-icon { font-size: 48rpx; color: #FFF; font-weight: 300; }


/* Pagination */
.loading-more { text-align: center; padding: 24rpx; }
.loading-text { font-size: 24rpx; color: var(--color-text-secondary); }
.no-more { text-align: center; padding: 24rpx; }
.no-more-text { font-size: 22rpx; color: var(--color-text-placeholder); }

.template-btn { display: flex; align-items: center; gap: 8rpx; background: var(--color-primary); border-radius: 999rpx; padding: 12rpx 24rpx; margin: 16rpx 0; }
.template-icon { font-size: 28rpx; color: #fff; font-weight: 700; }
.template-label { font-size: 24rpx; color: #fff; font-weight: 500; }

/* Batch Operations */
.batch-bar { position: fixed; bottom: calc(120rpx + env(safe-area-inset-bottom)); left: 0; right: 0; background: var(--color-card); padding: 20rpx 32rpx; display: flex; align-items: center; justify-content: space-between; box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.08); z-index: 90; transform: translateY(100%); transition: transform 0.2s ease; }
.batch-bar.show { transform: translateY(0); }
.batch-info { flex: 1; }
.batch-count { font-size: 26rpx; color: var(--color-text); font-weight: 600; }
.batch-actions { display: flex; gap: 16rpx; }
.batch-btn { padding: 10rpx 20rpx; border-radius: 999rpx; background: var(--csl-surface-muted); font-size: 24rpx; color: var(--color-text); }
.batch-danger { background: #FEE2E2; color: #DC3545; }

.note-card.selected { border: 3rpx solid var(--color-primary); background: var(--color-primary-bg); }

/* Three-Tab Bar */
.tab-bar { display: flex; gap: 8rpx; margin: 16rpx 0 8rpx; background: var(--csl-surface-muted); border-radius: var(--radius-lg); padding: 6rpx; }
.tab { flex: 1; text-align: center; padding: 16rpx 0; border-radius: var(--radius-md); font-size: 26rpx; color: var(--color-text-secondary); font-weight: 500; transition: all 0.2s ease; }
.tab.active { background: var(--color-card); color: var(--color-primary); font-weight: 600; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06); }
.tab-press { transform: scale(0.96); }

/* Tags Grid */
.tags-grid { display: flex; flex-wrap: wrap; gap: 16rpx; margin-top: 20rpx; }
.tag-card { width: calc(50% - 8rpx); background: var(--color-card); border-radius: var(--radius-lg); padding: 24rpx; box-shadow: var(--shadow-sm); transition: transform 0.2s ease; }
.tag-card:active { transform: scale(0.97); }
.tag-card-label { display: block; font-size: 28rpx; font-weight: 600; color: var(--color-primary); margin-bottom: 8rpx; }
.tag-card-count { display: block; font-size: 22rpx; color: var(--color-text-secondary); }
.tag-press { transform: scale(0.97); }

/* Graph Preview */
.graph-preview { background: var(--color-card); border-radius: var(--radius-lg); padding: 48rpx 32rpx; text-align: center; margin-top: 20rpx; box-shadow: var(--shadow-card); transition: transform 0.2s ease; }
.graph-preview:active { transform: scale(0.98); }
.graph-preview-icon { font-size: 80rpx; margin-bottom: 16rpx; }
.graph-preview-title { display: block; font-size: 32rpx; font-weight: 700; color: var(--color-text); margin-bottom: 8rpx; }
.graph-preview-desc { display: block; font-size: 24rpx; color: var(--color-text-secondary); margin-bottom: 16rpx; }
.graph-preview-hint { display: block; font-size: 26rpx; color: var(--color-primary); font-weight: 500; }
.graph-press { transform: scale(0.98); }

/* Graph Stats */
.graph-stats { display: flex; flex-wrap: wrap; gap: 12rpx; margin-top: 20rpx; }
.stat-card { display: flex; align-items: center; gap: 10rpx; background: var(--color-card); border-radius: var(--radius-md); padding: 16rpx 20rpx; min-width: 140rpx; }
.stat-dot { width: 12rpx; height: 12rpx; border-radius: 50%; flex-shrink: 0; }
.stat-label { font-size: 24rpx; color: var(--color-text-secondary); }
.stat-count { font-size: 26rpx; font-weight: 600; color: var(--color-text); margin-left: auto; }
