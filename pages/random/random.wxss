/* pages/random/random.wxss */
@import '../../styles/variables.wxss';
@import '../../styles/mixins.wxss';

.page { display: flex; flex-direction: column; height: 100vh; background: var(--color-bg); }
.page-scroll { flex: 1; }
.content { padding: 32rpx 40rpx; padding-bottom: calc(120rpx + env(safe-area-inset-bottom)); }

.header { margin-bottom: 32rpx; }
.page-title { font-size: 44rpx; font-weight: 700; color: var(--color-text); }

.mode-tabs { display: flex; gap: 16rpx; margin-bottom: 40rpx; }
.mode-tab { flex: 1; text-align: center; padding: 16rpx 0; border-radius: 24rpx; background: var(--color-card); font-size: 26rpx; color: var(--color-text-secondary); }
.mode-tab.active { background: var(--color-primary); color: #fff; font-weight: 600; }

.result-area { min-height: 200rpx; display: flex; align-items: center; justify-content: center; margin-bottom: 40rpx; opacity: 0; transform: scale(0.8); transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1); }
.result-area.anim-show { opacity: 1; transform: scale(1); }
.result-text { font-size: 72rpx; font-weight: 700; color: var(--color-primary); }

.action-area { display: flex; flex-direction: column; align-items: center; gap: 24rpx; margin-bottom: 40rpx; }
.action-btn-main { width: 240rpx; height: 240rpx; border-radius: 50%; background: var(--csl-gradient); display: flex; align-items: center; justify-content: center; font-size: 36rpx; color: #fff; font-weight: 600; box-shadow: 0 12rpx 32rpx rgba(91,76,255,0.3); }
.btn-press { opacity: 0.85; transform: scale(0.95); }

.dice-count { width: 100%; display: flex; align-items: center; gap: 16rpx; }
.count-label { font-size: 26rpx; color: var(--color-text-secondary); white-space: nowrap; }
.dice-display { display: flex; gap: 20rpx; }
.dice-icon { font-size: 48rpx; font-weight: 700; color: var(--color-primary); }

.question-input { width: 100%; height: 80rpx; border: 2rpx solid var(--color-border); border-radius: 24rpx; padding: 0 24rpx; font-size: 28rpx; }

.history-section { background: var(--color-card); border-radius: 24rpx; padding: 24rpx; }
.section-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.section-title { font-size: 28rpx; font-weight: 600; color: var(--color-text); }
.clear-btn { font-size: 24rpx; color: var(--color-text-secondary); }
.history-item { display: flex; justify-content: space-between; align-items: center; padding: 12rpx 0; border-bottom: 1rpx solid var(--color-border); }
.history-item:last-child { border-bottom: none; }
.history-text { font-size: 26rpx; color: var(--color-text); }
.history-time { font-size: 22rpx; color: var(--color-text-secondary); }

.anim-fade { opacity: 0; transform: translateY(24rpx); transition: opacity 0.4s ease, transform 0.4s ease; }
.anim-show { opacity: 1; transform: translateY(0); }
.anim-d1 { transition-delay: 0.06s; }
.anim-d2 { transition-delay: 0.12s; }
.anim-d3 { transition-delay: 0.18s; }
.press { opacity: 0.7; transform: scale(0.96); }
