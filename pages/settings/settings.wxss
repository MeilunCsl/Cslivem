/* pages/settings/settings.wxss */
.page {
  height: 100vh;
  background: #F7F8FB;
  display: flex;
  flex-direction: column;
}
.page-scroll {
  flex: 1;
  height: 0;
}
.content {
  padding: 24rpx 32rpx;
  padding-bottom: calc(190rpx + env(safe-area-inset-bottom));
}
.anim-fade-up {
  opacity: 0;
  transform: translateY(30rpx);
  transition: opacity 0.5s ease, transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
}
.anim-visible {
  opacity: 1;
  transform: translateY(0);
}
.anim-d1 { transition-delay: 0.1s; }
.anim-d2 { transition-delay: 0.2s; }
.anim-d3 { transition-delay: 0.3s; }
.section {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}
.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #0A0F1A;
  margin-bottom: 24rpx;
}
.provider-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.provider-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-radius: 16rpx;
  border: 2rpx solid #E7EAF0;
  transition: all 0.2s ease;
}
.provider-active {
  border-color: #5B4CFF;
  background: rgba(91, 76, 255, 0.04);
}
.provider-radio {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 3rpx solid #D0D5DD;
  margin-right: 20rpx;
  flex-shrink: 0;
  position: relative;
}
.radio-active {
  border-color: #5B4CFF;
  background: #5B4CFF;
}
.radio-active::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #FFFFFF;
}
.provider-info {
  display: flex;
  flex-direction: column;
}
.provider-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #0A0F1A;
  margin-bottom: 6rpx;
}
.provider-desc {
  font-size: 24rpx;
  color: #7B8197;
}
.config-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F2F4F8;
}
.config-input-row {
  flex-direction: column;
  align-items: flex-start;
  gap: 12rpx;
}
.config-label {
  font-size: 26rpx;
  color: #3A3F50;
  font-weight: 500;
}
.config-input {
  width: 100%;
  height: 80rpx;
  background: #F7F8FB;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 26rpx;
  color: #0A0F1A;
  box-sizing: border-box;
}
.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 80rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #5B4CFF, #3A7BFF);
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 600;
  margin-top: 20rpx;
  transition: transform 0.15s ease, opacity 0.15s ease;
}
.btn-press {
  transform: scale(0.97);
  opacity: 0.85;
}
.action-secondary {
  background: #F2F4F8;
  color: #3A3F50;
}
.action-danger {
  background: #FFF0F0;
  color: #E5484D;
}
.test-btn {
  margin-top: 24rpx;
}
.test-result {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #7B8197;
  padding: 16rpx;
  background: #F7F8FB;
  border-radius: 12rpx;
}
.status-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-bottom: 20rpx;
}
.status-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  background: #F7F8FB;
  border-radius: 16rpx;
}
.status-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #5B4CFF;
}
.status-label {
  font-size: 22rpx;
  color: #7B8197;
  margin-top: 6rpx;
}
.status-detail {
  margin-bottom: 16rpx;
}
.status-time {
  font-size: 22rpx;
  color: #A5AEC0;
}
.action-row {
  display: flex;
  gap: 16rpx;
}
.action-row .action-btn {
  flex: 1;
  margin-top: 0;
}
.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  margin-bottom: 24rpx;
}
.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx;
  background: #F7F8FB;
  border-radius: 16rpx;
}
.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #0A0F1A;
}
.stat-label {
  font-size: 22rpx;
  color: #7B8197;
  margin-top: 8rpx;
}
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0);
  z-index: -1;
  pointer-events: none;
  transition: background 0.28s ease;
}
.modal-overlay.show {
  z-index: 199;
  background: rgba(10, 15, 26, 0.45);
  pointer-events: auto;
}
.modal {
  position: fixed;
  left: 48rpx;
  right: 48rpx;
  top: 50%;
  transform: translateY(-50%) scale(0.95);
  background: #FFFFFF;
  border-radius: 28rpx;
  padding: 40rpx;
  z-index: 200;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.24s ease, transform 0.28s cubic-bezier(0.22, 1, 0.36, 1);
}
.modal-in {
  opacity: 1;
  transform: translateY(-50%) scale(1);
  pointer-events: auto;
}
.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  text-align: center;
  margin-bottom: 28rpx;
  color: #0A0F1A;
}
.modal-body {
  margin-bottom: 28rpx;
}
.preview-item {
  padding: 12rpx 0;
  font-size: 26rpx;
  color: #3A3F50;
  border-bottom: 1rpx solid #F2F4F8;
}
.modal-tip {
  margin-top: 16rpx;
  font-size: 22rpx;
  color: #A5AEC0;
  text-align: center;
}
.modal-actions {
  display: flex;
  gap: 16rpx;
}
.modal-btn {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  background: #F2F4F8;
  color: #3A3F50;
  transition: transform 0.15s ease;
}
.modal-btn:active {
  transform: scale(0.97);
}
.modal-btn-primary {
  background: linear-gradient(135deg, #5B4CFF, #3A7BFF);
  color: #FFFFFF;
}
.import-textarea {
  width: 100%;
  min-height: 200rpx;
  background: #F7F8FB;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 24rpx;
  color: #0A0F1A;
  box-sizing: border-box;
}
