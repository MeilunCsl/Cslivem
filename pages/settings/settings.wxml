<!-- pages/settings/settings.wxml -->
<view class="page">
  <view style="height: {{statusBarHeight}}px;"></view>
  <scroll-view scroll-y class="page-scroll" enhanced show-scrollbar="{{false}}">
    <view class="content">
      <view class="section anim-fade {{ready ? 'anim-show' : ''}}">
        <view class="section-title">AI 模型</view>
        <view class="provider-list">
          <view class="provider-item {{activeProvider === item.id ? 'provider-active' : ''}}" wx:for="{{providers}}" wx:key="id" bindtap="onProviderChange" data-provider="{{item.id}}">
            <view class="provider-radio {{activeProvider === item.id ? 'radio-active' : ''}}"></view>
            <view class="provider-info">
              <text class="provider-name">{{item.name}}</text>
              <text class="provider-desc">{{item.desc}}</text>
            </view>
          </view>
        </view>
      </view>

      <view class="section anim-fade anim-d1 {{ready ? 'anim-show' : ''}}" wx:if="{{activeProvider !== 'ecs'}}">
        <view class="section-title">提供商配置</view>
        <view class="config-row">
          <text class="config-label">启用</text>
          <switch checked="{{providerEnabled}}" bindchange="onProviderEnabledChange" color="#5B4CFF" />
        </view>
        <view class="config-row config-input-row">
          <text class="config-label">Endpoint</text>
          <input class="config-input" value="{{providerEndpoint}}" bindinput="onProviderEndpointInput" bindblur="onProviderEndpointSave" placeholder="http://127.0.0.1:11434/v1/chat/completions" />
        </view>
        <view class="config-row config-input-row">
          <text class="config-label">API Key</text>
          <input class="config-input" value="{{providerApiKey}}" bindinput="onProviderApiKeyInput" bindblur="onProviderApiKeySave" placeholder="可选" password="true" />
        </view>
        <view class="config-row config-input-row">
          <text class="config-label">Model</text>
          <input class="config-input" value="{{providerModel}}" bindinput="onProviderModelInput" bindblur="onProviderModelSave" placeholder="mimo" />
        </view>
        <view class="action-btn test-btn" bindtap="onTestConnection" hover-class="btn-press">
          <text>{{testingConnection ? '测试中...' : '测试连接'}}</text>
        </view>
        <view class="test-result" wx:if="{{testResult}}">{{testResult}}</view>
      </view>

      <view class="section anim-fade anim-d1 {{ready ? 'anim-show' : ''}}" wx:if="{{activeProvider === 'ecs'}}">
        <view class="section-title">ECS 代理配置</view>
        <view class="config-row">
          <text class="config-label">启用</text>
          <switch checked="{{providerEnabled}}" bindchange="onProviderEnabledChange" color="#5B4CFF" />
        </view>
        <view class="config-row config-input-row">
          <text class="config-label">Endpoint</text>
          <input class="config-input" value="{{providerEndpoint}}" bindinput="onProviderEndpointInput" bindblur="onProviderEndpointSave" placeholder="https://your-ecs-server.com/v1/chat/completions" />
        </view>
        <view class="config-row config-input-row">
          <text class="config-label">API Key</text>
          <input class="config-input" value="{{providerApiKey}}" bindinput="onProviderApiKeyInput" bindblur="onProviderApiKeySave" placeholder="Bearer Token" password="true" />
        </view>
        <view class="config-row config-input-row">
          <text class="config-label">Model</text>
          <input class="config-input" value="{{providerModel}}" bindinput="onProviderModelInput" bindblur="onProviderModelSave" placeholder="qwen-plus" />
        </view>
        <view class="action-btn test-btn" bindtap="onTestConnection" hover-class="btn-press">
          <text>{{testingConnection ? '测试中...' : '测试连接'}}</text>
        </view>
        <view class="test-result" wx:if="{{testResult}}">{{testResult}}</view>
      </view>

      <view class="section anim-fade anim-d2 {{ready ? 'anim-show' : ''}}">
        <view class="section-title">同步状态</view>
        <view class="status-grid">
          <view class="status-item">
            <text class="status-value">{{syncStatus.pending}}</text>
            <text class="status-label">待同步</text>
          </view>
          <view class="status-item">
            <text class="status-value">{{syncStatus.failed}}</text>
            <text class="status-label">失败</text>
          </view>
          <view class="status-item">
            <text class="status-value">{{syncStatus.version}}</text>
            <text class="status-label">版本</text>
          </view>
        </view>
        <view class="status-detail" wx:if="{{syncStatus.lastSyncAt}}">
          <text class="status-time">上次同步: {{syncStatus.lastSyncAt}}</text>
        </view>
        <view class="action-row">
          <view class="action-btn" bindtap="onSync" hover-class="btn-press"><text>立即同步</text></view>
          <view class="action-btn action-secondary" bindtap="onRetryFailed" wx:if="{{syncStatus.failed > 0}}" hover-class="btn-press"><text>重试失败</text></view>
          <view class="action-btn action-danger" bindtap="onClearQueue" wx:if="{{syncStatus.total > 0}}" hover-class="btn-press"><text>清空队列</text></view>
        </view>
      </view>

            <view class="section anim-fade anim-d3 {{ready ? 'anim-show' : ''}}">
        <view class="section-title">域名白名单配置</view>
        <view style="font-size: 24rpx; color: #7B8197; line-height: 1.6; margin-bottom: 20rpx;">
          <text>微信小程序要求所有请求域名必须在管理后台注册。</text>
        </view>
        <view style="font-size: 24rpx; color: #3A3F50; line-height: 1.8;">
          <text>1. 打开微信小程序管理平台 → 开发 → 开发设置 → 服务域名</text>
        </view>
        <view style="font-size: 24rpx; color: #3A3F50; line-height: 1.8;">
          <text>2. 在 request 合法域名中添加以下域名：</text>
        </view>
        <view style="margin-top: 12rpx; padding: 16rpx; background: #F7F8FB; border-radius: 12rpx;">
          <text style="font-size: 22rpx; color: #5B4CFF; font-weight: 600;">MiMo</text>
          <text style="font-size: 22rpx; color: #7B8197;">  token-plan-cn.xiaomimimo.com</text>
        </view>
        <view style="margin-top: 8rpx; padding: 16rpx; background: #F7F8FB; border-radius: 12rpx;">
          <text style="font-size: 22rpx; color: #5B4CFF; font-weight: 600;">DashScope</text>
          <text style="font-size: 22rpx; color: #7B8197;">  dashscope.aliyuncs.com</text>
        </view>
        <view style="margin-top: 8rpx; padding: 16rpx; background: #F7F8FB; border-radius: 12rpx;">
          <text style="font-size: 22rpx; color: #5B4CFF; font-weight: 600;">DeepSeek</text>
          <text style="font-size: 22rpx; color: #7B8197;">  api.deepseek.com</text>
        </view>
        <view style="margin-top: 8rpx; padding: 16rpx; background: #F7F8FB; border-radius: 12rpx;">
          <text style="font-size: 22rpx; color: #5B4CFF; font-weight: 600;">OpenAI</text>
          <text style="font-size: 22rpx; color: #7B8197;">  api.openai.com</text>
        </view>
        <view style="margin-top: 8rpx; padding: 16rpx; background: #F7F8FB; border-radius: 12rpx;">
          <text style="font-size: 22rpx; color: #5B4CFF; font-weight: 600;">Zhipu</text>
          <text style="font-size: 22rpx; color: #7B8197;">  open.bigmodel.cn</text>
        </view>
      </view>

<view class="section anim-fade anim-d3 {{ready ? 'anim-show' : ''}}">
        <view class="section-title">数据管理</view>
        <view class="stats-grid">
          <view class="stat-item">
            <text class="stat-value">{{dataStats.graphNodes}}</text>
            <text class="stat-label">知识节点</text>
          </view>
          <view class="stat-item">
            <text class="stat-value">{{dataStats.graphEdges}}</text>
            <text class="stat-label">关联边</text>
          </view>
          <view class="stat-item">
            <text class="stat-value">{{dataStats.notes}}</text>
            <text class="stat-label">笔记</text>
          </view>
          <view class="stat-item">
            <text class="stat-value">{{dataStats.storageUsed}}</text>
            <text class="stat-label">存储占用</text>
          </view>
        </view>
        <view class="action-row">
          <view class="action-btn" bindtap="onExport" hover-class="btn-press"><text>导出数据</text></view>
          <view class="action-btn action-secondary" bindtap="onImport" hover-class="btn-press"><text>导入数据</text></view>
        </view>
        <view class="action-row" style="margin-top: 20rpx;">
          <view class="action-btn action-danger" bindtap="onResetGraph" hover-class="btn-press"><text>重置知识图谱</text></view>
        </view>
      </view>
    </view>
  </scroll-view>

  <view class="modal-overlay {{showExportModal ? 'show' : ''}}" catchtap="onExportClose"></view>
  <view class="modal {{showExportModal ? 'modal-in' : ''}}">
    <view class="modal-title">导出数据</view>
    <view class="modal-body" wx:if="{{exportPreview}}">
      <view class="preview-item"><text>知识节点: {{exportPreview.graphNodes}}</text></view>
      <view class="preview-item"><text>关联边: {{exportPreview.graphEdges}}</text></view>
      <view class="preview-item"><text>笔记: {{exportPreview.notes}}</text></view>
      <view class="preview-item"><text>日历事件: {{exportPreview.calendarEvents}}</text></view>
      <view class="preview-item"><text>账单: {{exportPreview.ledgerTransactions}}</text></view>
      <view class="modal-tip">导出数据将复制到剪贴板</view>
    </view>
    <view class="modal-actions">
      <view class="modal-btn" bindtap="onExportClose">取消</view>
      <view class="modal-btn modal-btn-primary" bindtap="onExportConfirm">确认导出</view>
    </view>
  </view>

  <view class="modal-overlay {{showImportModal ? 'show' : ''}}" catchtap="onImportClose"></view>
  <view class="modal {{showImportModal ? 'modal-in' : ''}}">
    <view class="modal-title">导入数据</view>
    <view class="modal-body">
      <textarea class="import-textarea" value="{{importJson}}" bindinput="onImportJsonInput" placeholder="粘贴导出的 JSON 数据..." maxlength="-1" auto-height />
      <view class="action-btn action-secondary" bindtap="onImportFromClipboard" hover-class="btn-press" style="margin-top: 16rpx;">
        <text>从剪贴板粘贴</text>
      </view>
      <view class="modal-tip">导入将合并到现有数据，相同ID的更新为最新版本</view>
    </view>
    <view class="modal-actions">
      <view class="modal-btn" bindtap="onImportClose">取消</view>
      <view class="modal-btn modal-btn-primary" bindtap="onImportConfirm">确认导入</view>
    </view>
  </view>
</view>
