<!-- pages/settings/settings.wxml -->
<view class="page">
  <view style="height: {{statusBarHeight}}px;"></view>

  <scroll-view scroll-y class="page-scroll" enhanced show-scrollbar="{{false}}">
    <view class="content">

      <!-- AI Provider -->
      <view class="section anim-fade-up {{ready ? 'anim-visible' : ''}}">
        <view class="section-title">AI ??</view>

        <view class="provider-list">
          <view
            class="provider-item {{activeProvider === 'mimo' ? 'provider-active' : ''}}"
            bindtap="onProviderChange"
            data-provider="mimo"
          >
            <view class="provider-radio {{activeProvider === 'mimo' ? 'radio-active' : ''}}"></view>
            <view class="provider-info">
              <text class="provider-name">MiMo (??)</text>
              <text class="provider-desc">?? MiMo ?????OpenAI ????</text>
            </view>
          </view>
          <view
            class="provider-item {{activeProvider === 'ecs' ? 'provider-active' : ''}}"
            bindtap="onProviderChange"
            data-provider="ecs"
          >
            <view class="provider-radio {{activeProvider === 'ecs' ? 'radio-active' : ''}}"></view>
            <view class="provider-info">
              <text class="provider-name">ECS ???</text>
              <text class="provider-desc">??? / ???????</text>
            </view>
          </view>
        </view>
      </view>

      <!-- MiMo Config -->
      <view class="section anim-fade-up anim-d1 {{ready ? 'anim-visible' : ''}}" wx:if="{{activeProvider === 'mimo'}}">
        <view class="section-title">MiMo ??</view>

        <view class="config-row">
          <text class="config-label">??</text>
          <switch checked="{{mimoEnabled}}" bindchange="onMimoEnabledChange" color="#5B4CFF" />
        </view>

        <view class="config-row config-input-row">
          <text class="config-label">Endpoint</text>
          <input
            class="config-input"
            value="{{mimoEndpoint}}"
            bindinput="onMimoEndpointInput"
            bindblur="onMimoEndpointSave"
            placeholder="http://127.0.0.1:11434/v1/chat/completions"
          />
        </view>

        <view class="config-row config-input-row">
          <text class="config-label">API Key</text>
          <input
            class="config-input"
            value="{{mimoApiKey}}"
            bindinput="onMimoApiKeyInput"
            bindblur="onMimoApiKeySave"
            placeholder="??"
            password="true"
          />
        </view>

        <view class="config-row config-input-row">
          <text class="config-label">Model</text>
          <input
            class="config-input"
            value="{{mimoModel}}"
            bindinput="onMimoModelInput"
            bindblur="onMimoModelSave"
            placeholder="mimo"
          />
        </view>

        <view class="action-btn test-btn" bindtap="onTestConnection" hover-class="btn-press">
          <text>{{testingConnection ? '???...' : '????'}}</text>
        </view>
        <view class="test-result" wx:if="{{testResult}}">{{testResult}}</view>
      </view>

      <!-- ECS Config -->
      <view class="section anim-fade-up anim-d1 {{ready ? 'anim-visible' : ''}}" wx:if="{{activeProvider === 'ecs'}}">
        <view class="section-title">ECS ??</view>

        <view class="config-row">
          <text class="config-label">??</text>
          <switch checked="{{ecsEnabled}}" bindchange="onEcsEnabledChange" color="#5B4CFF" />
        </view>

        <view class="config-row config-input-row">
          <text class="config-label">Endpoint</text>
          <input
            class="config-input"
            value="{{ecsEndpoint}}"
            bindinput="onEcsEndpointInput"
            bindblur="onEcsEndpointSave"
            placeholder="https://your-ecs-server.com/v1/chat/completions"
          />
        </view>

        <view class="config-row config-input-row">
          <text class="config-label">API Key</text>
          <input
            class="config-input"
            value="{{ecsApiKey}}"
            bindinput="onEcsApiKeyInput"
            bindblur="onEcsApiKeySave"
            placeholder="Bearer Token"
            password="true"
          />
        </view>

        <view class="config-row config-input-row">
          <text class="config-label">Model</text>
          <input
            class="config-input"
            value="{{ecsModel}}"
            bindinput="onEcsModelInput"
            bindblur="onEcsModelSave"
            placeholder="qwen-plus"
          />
        </view>

        <view class="action-btn test-btn" bindtap="onTestConnection" hover-class="btn-press">
          <text>{{testingConnection ? '???...' : '????'}}</text>
        </view>
        <view class="test-result" wx:if="{{testResult}}">{{testResult}}</view>
      </view>

      <!-- Sync Status -->
      <view class="section anim-fade-up anim-d2 {{ready ? 'anim-visible' : ''}}">
        <view class="section-title">????</view>

        <view class="status-grid">
          <view class="status-item">
            <text class="status-value">{{syncStatus.pending}}</text>
            <text class="status-label">???</text>
          </view>
          <view class="status-item">
            <text class="status-value">{{syncStatus.failed}}</text>
            <text class="status-label">??</text>
          </view>
          <view class="status-item">
            <text class="status-value">{{syncStatus.version}}</text>
            <text class="status-label">??</text>
          </view>
        </view>

        <view class="status-detail" wx:if="{{syncStatus.lastSyncAt}}">
          <text class="status-time">????: {{syncStatus.lastSyncAt}}</text>
        </view>

        <view class="action-row">
          <view class="action-btn" bindtap="onSync" hover-class="btn-press">
            <text>????</text>
          </view>
          <view class="action-btn action-secondary" bindtap="onRetryFailed" wx:if="{{syncStatus.failed > 0}}" hover-class="btn-press">
            <text>????</text>
          </view>
          <view class="action-btn action-danger" bindtap="onClearQueue" wx:if="{{syncStatus.total > 0}}" hover-class="btn-press">
            <text>????</text>
          </view>
        </view>
      </view>

      <!-- Data Management -->
      <view class="section anim-fade-up anim-d3 {{ready ? 'anim-visible' : ''}}">
        <view class="section-title">????</view>

        <view class="stats-grid">
          <view class="stat-item">
            <text class="stat-value">{{dataStats.graphNodes}}</text>
            <text class="stat-label">????</text>
          </view>
          <view class="stat-item">
            <text class="stat-value">{{dataStats.graphEdges}}</text>
            <text class="stat-label">???</text>
          </view>
          <view class="stat-item">
            <text class="stat-value">{{dataStats.notes}}</text>
            <text class="stat-label">??</text>
          </view>
          <view class="stat-item">
            <text class="stat-value">{{dataStats.storageUsed}}</text>
            <text class="stat-label">????</text>
          </view>
        </view>

        <view class="action-row">
          <view class="action-btn" bindtap="onExport" hover-class="btn-press">
            <text>????</text>
          </view>
          <view class="action-btn action-secondary" bindtap="onImport" hover-class="btn-press">
            <text>????</text>
          </view>
        </view>

        <view class="action-row" style="margin-top: 20rpx;">
          <view class="action-btn action-danger" bindtap="onResetGraph" hover-class="btn-press">
            <text>??????</text>
          </view>
        </view>
      </view>

    </view>
  </scroll-view>

  <!-- Export Modal -->
  <view class="modal-overlay {{showExportModal ? 'show' : ''}}" catchtap="onExportClose"></view>
  <view class="modal {{showExportModal ? 'modal-in' : ''}}">
    <view class="modal-title">????</view>
    <view class="modal-body" wx:if="{{exportPreview}}">
      <view class="preview-item">
        <text>????: {{exportPreview.graphNodes}}</text>
      </view>
      <view class="preview-item">
        <text>???: {{exportPreview.graphEdges}}</text>
      </view>
      <view class="preview-item">
        <text>??: {{exportPreview.notes}}</text>
      </view>
      <view class="preview-item">
        <text>????: {{exportPreview.calendarEvents}}</text>
      </view>
      <view class="preview-item">
        <text>??: {{exportPreview.ledgerTransactions}}</text>
      </view>
      <view class="modal-tip">???????????</view>
    </view>
    <view class="modal-actions">
      <view class="modal-btn" bindtap="onExportClose">??</view>
      <view class="modal-btn modal-btn-primary" bindtap="onExportConfirm">????</view>
    </view>
  </view>

  <!-- Import Modal -->
  <view class="modal-overlay {{showImportModal ? 'show' : ''}}" catchtap="onImportClose"></view>
  <view class="modal {{showImportModal ? 'modal-in' : ''}}">
    <view class="modal-title">????</view>
    <view class="modal-body">
      <textarea
        class="import-textarea"
        value="{{importJson}}"
        bindinput="onImportJsonInput"
        placeholder="????? JSON ??..."
        maxlength="-1"
        auto-height
      />
      <view class="action-btn action-secondary" bindtap="onImportFromClipboard" hover-class="btn-press" style="margin-top: 16rpx;">
        <text>??????</text>
      </view>
      <view class="modal-tip">?????????????ID????????</view>
    </view>
    <view class="modal-actions">
      <view class="modal-btn" bindtap="onImportClose">??</view>
      <view class="modal-btn modal-btn-primary" bindtap="onImportConfirm">????</view>
    </view>
  </view>

</view>
