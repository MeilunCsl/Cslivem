/* pages/habit/habit.wxss */
.page { height: 100vh; background: var(--color-bg); display: flex; flex-direction: column; }
.nav-bar { display: flex; align-items: center; height: 88rpx; padding: 0 24rpx; background: var(--color-card); border-bottom: 1rpx solid var(--color-divider); }
.nav-back { font-size: 48rpx; color: var(--color-primary); padding: 0 16rpx; }
.nav-title { flex: 1; text-align: center; font-size: 32rpx; font-weight: 600; color: var(--color-text); }
.content { flex: 1; padding: 24rpx var(--csl-page-x); }

.stats-bar { display: flex; gap: 16rpx; margin-bottom: 24rpx; }
.stat-item { flex: 1; background: var(--color-card); border-radius: var(--radius-lg); padding: 24rpx; text-align: center; }
.stat-value { display: block; font-size: 40rpx; font-weight: 700; color: var(--color-primary); }
.stat-label { display: block; font-size: 22rpx; color: var(--color-text-secondary); margin-top: 4rpx; }

.habit-list { margin-bottom: 24rpx; }
.habit-card {
  display: flex; align-items: center; gap: 20rpx;
  padding: 24rpx; background: var(--color-card);
  border-radius: var(--radius-lg); margin-bottom: 12rpx;
  transition: all 0.2s ease;
}
.habit-done { opacity: 0.85; }
.habit-check { padding: 8rpx; }
.check-press { transform: scale(0.9); }
.check-circle {
  width: 72rpx; height: 72rpx; border-radius: 50%;
  border: 3rpx solid; display: flex; align-items: center; justify-content: center;
  transition: all 0.2s ease;
}
.check-icon { font-size: 32rpx; color: #FFF; }
.habit-info { flex: 1; }
.habit-name { display: block; font-size: 30rpx; font-weight: 600; color: var(--color-text); }
.habit-streak { display: block; font-size: 22rpx; color: var(--color-text-secondary); margin-top: 4rpx; }
.habit-delete { padding: 8rpx 12rpx; }
.delete-icon { font-size: 32rpx; color: var(--color-text-secondary); }

.empty-state { display: flex; flex-direction: column; align-items: center; padding: 80rpx 0; }
.empty-icon { font-size: 80rpx; color: var(--color-text-secondary); margin-bottom: 16rpx; }
.empty-text { font-size: 30rpx; font-weight: 600; color: var(--color-text); margin-bottom: 8rpx; }
.empty-hint { font-size: 26rpx; color: var(--color-text-secondary); }

.create-btn {
  height: 80rpx; display: flex; align-items: center; justify-content: center;
  background: var(--color-card); border-radius: var(--radius-lg);
  border: 2rpx dashed var(--color-border); color: var(--color-primary);
  font-size: 28rpx; margin-bottom: 24rpx;
}
.btn-press { opacity: 0.7; transform: scale(0.98); }

.create-form { background: var(--color-card); border-radius: var(--radius-lg); padding: 24rpx; margin-bottom: 24rpx; }
.form-input { height: 80rpx; background: var(--csl-surface-muted); border-radius: var(--radius-md); padding: 0 24rpx; font-size: 28rpx; margin-bottom: 20rpx; }
.form-section { margin-bottom: 20rpx; }
.form-label { font-size: 26rpx; color: var(--color-text-secondary); margin-bottom: 12rpx; display: block; }
.icon-grid { display: flex; flex-wrap: wrap; gap: 12rpx; }
.icon-option { width: 64rpx; height: 64rpx; display: flex; align-items: center; justify-content: center; border-radius: var(--radius-md); background: var(--csl-surface-muted); font-size: 32rpx; }
.icon-selected { background: var(--color-primary-bg); border: 2rpx solid var(--color-primary); }
.color-grid { display: flex; flex-wrap: wrap; gap: 12rpx; }
.color-option { width: 56rpx; height: 56rpx; border-radius: 50%; border: 3rpx solid transparent; }
.color-selected { border-color: var(--color-text); transform: scale(1.15); }

.submit-btn {
  height: 80rpx; display: flex; align-items: center; justify-content: center;
  background: var(--csl-gradient); border-radius: var(--radius-lg);
  color: #FFF; font-size: 28rpx; font-weight: 600;
}
