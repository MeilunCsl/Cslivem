/* pages/compress/compress.wxss */
.page { height: 100vh; background: var(--color-bg); display: flex; flex-direction: column; }
.nav-bar { display: flex; align-items: center; height: 88rpx; padding: 0 24rpx; background: var(--color-card); border-bottom: 1rpx solid var(--color-divider); }
.nav-back { font-size: 48rpx; color: var(--color-primary); padding: 0 16rpx; }
.nav-title { flex: 1; text-align: center; font-size: 32rpx; font-weight: 600; color: var(--color-text); }
.content { flex: 1; padding: 24rpx var(--csl-page-x); }
.section-title { font-size: 28rpx; font-weight: 600; color: var(--color-text); margin-bottom: 16rpx; display: block; }
.empty-state { display: flex; flex-direction: column; align-items: center; padding: 80rpx 0 40rpx; }
.empty-icon { font-size: 80rpx; color: var(--color-text-secondary); margin-bottom: 16rpx; }
.empty-text { font-size: 28rpx; color: var(--color-text-secondary); }
.select-btn { height: 80rpx; display: flex; align-items: center; justify-content: center; background: var(--csl-gradient); border-radius: var(--radius-lg); color: #FFF; font-size: 28rpx; font-weight: 600; }
.btn-press { opacity: 0.7; }
.preview-grid { display: flex; flex-wrap: wrap; gap: 12rpx; margin-bottom: 20rpx; }
.preview-item { position: relative; width: 200rpx; height: 200rpx; border-radius: var(--radius-md); overflow: hidden; }
.preview-img { width: 100%; height: 100%; }
.preview-size { position: absolute; bottom: 4rpx; right: 4rpx; background: rgba(0,0,0,0.5); color: #FFF; font-size: 20rpx; padding: 2rpx 8rpx; border-radius: var(--radius-sm); }
.quality-section { margin-bottom: 20rpx; }
.quality-label { font-size: 26rpx; color: var(--color-text); margin-bottom: 8rpx; display: block; }
.compress-btn { height: 80rpx; display: flex; align-items: center; justify-content: center; background: var(--csl-gradient); border-radius: var(--radius-lg); color: #FFF; font-size: 28rpx; font-weight: 600; }
.loading-text { text-align: center; padding: 40rpx; font-size: 28rpx; color: var(--color-text-secondary); }
.result-item { display: flex; align-items: center; gap: 16rpx; padding: 12rpx; background: var(--color-card); border-radius: var(--radius-md); margin-bottom: 8rpx; }
.result-img { width: 80rpx; height: 80rpx; border-radius: var(--radius-sm); }
.result-info { flex: 1; }
.result-size { display: block; font-size: 28rpx; font-weight: 600; color: var(--color-text); }
.result-dim { display: block; font-size: 22rpx; color: var(--color-text-secondary); }
.action-row { display: flex; gap: 16rpx; margin-top: 20rpx; }
.action-btn { flex: 1; height: 72rpx; display: flex; align-items: center; justify-content: center; background: var(--color-card); border-radius: var(--radius-md); font-size: 26rpx; color: var(--color-text); border: 1rpx solid var(--color-border); }
