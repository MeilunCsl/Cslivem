<view class="page anim-fade {{ready ? 'anim-show' : ''}}">
  <view class="nav-bar">
    <view class="nav-back" bindtap="onBack">‹</view>
    <view class="nav-title">图片压缩</view>
  </view>
  <scroll-view scroll-y class="content">
    <view class="empty-state" wx:if="{{images.length === 0 && results.length === 0}}">
      <text class="empty-icon">◄</text>
      <text class="empty-text">压缩图片、减小文件大小</text>
    </view>
    <view class="select-btn" bindtap="onSelectImages" hover-class="btn-press" wx:if="{{images.length === 0 && results.length === 0}}"><text>选择图片</text></view>

    <view wx:if="{{images.length > 0 && results.length === 0}}">
      <view class="section-title">已选 {{images.length}} 张</view>
      <view class="preview-grid">
        <view class="preview-item" wx:for="{{images}}" wx:key="path">
          <image class="preview-img" src="{{item.path}}" mode="aspectFill" />
          <text class="preview-size">{{item.sizeKB}}KB</text>
        </view>
      </view>
      <view class="quality-section">
        <text class="quality-label">压缩质量: {{quality}}%</text>
        <slider min="10" max="90" value="{{quality}}" bindchanging="onQualityChange" activeColor="#6C5CE7" />
      </view>
      <view class="compress-btn" bindtap="onCompress" hover-class="btn-press"><text>开始压缩</text></view>
    </view>

    <view wx:if="{{loading}}"><view class="loading-text">正在压缩...</view></view>

    <view wx:if="{{results.length > 0}}">
      <view class="section-title">压缩结果</view>
      <view class="result-item" wx:for="{{results}}" wx:key="path">
        <image class="result-img" src="{{item.path}}" mode="aspectFill" />
        <view class="result-info">
          <text class="result-size">{{item.sizeKB}}KB</text>
          <text class="result-dim">{{item.width}}x{{item.height}}</text>
        </view>
      </view>
      <view class="action-row">
        <view class="action-btn" bindtap="onSaveAll" hover-class="btn-press"><text>保存到相册</text></view>
        <view class="action-btn" bindtap="onReset" hover-class="btn-press"><text>重新选择</text></view>
      </view>
    </view>
  </scroll-view>
</view>
