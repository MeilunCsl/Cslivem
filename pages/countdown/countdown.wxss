/* pages/countdown/countdown.wxss */
.page { height: 100vh; background: var(--color-bg); display: flex; flex-direction: column; }
.nav-bar { display: flex; align-items: center; height: 88rpx; padding: 0 24rpx; background: var(--color-card); border-bottom: 1rpx solid var(--color-divider); }
.nav-back { font-size: 48rpx; color: var(--color-primary); padding: 0 16rpx; }
.nav-title { flex: 1; text-align: center; font-size: 32rpx; font-weight: 600; color: var(--color-text); }
.content { flex: 1; padding: 24rpx var(--csl-page-x); }

.cd-list { margin-bottom: 24rpx; }
.cd-card { display: flex; align-items: center; padding: 24rpx; background: var(--color-card); border-radius: var(--radius-lg); margin-bottom: 12rpx; gap: 16rpx; }
.cd-left { flex: 1; }
.cd-icon { font-size: 36rpx; margin-right: 12rpx; }
.cd-title { font-size: 30rpx; font-weight: 600; color: var(--color-text); }
.cd-date { display: block; font-size: 22rpx; color: var(--color-text-secondary); margin-top: 4rpx; margin-left: 48rpx; }
.cd-right { text-align: center; min-width: 120rpx; }
.cd-days { display: block; font-size: 40rpx; font-weight: 700; }
.cd-future { color: var(--color-primary); }
.cd-today { color: var(--color-success); }
.cd-past { color: var(--color-text-secondary); }
.cd-label { display: block; font-size: 20rpx; color: var(--color-text-secondary); }
.cd-delete { padding: 8rpx 12rpx; font-size: 28rpx; color: var(--color-text-secondary); }

.empty-state { display: flex; flex-direction: column; align-items: center; padding: 80rpx 0; }
.empty-icon { font-size: 80rpx; margin-bottom: 16rpx; }
.empty-text { font-size: 28rpx; color: var(--color-text-secondary); }

.create-btn { height: 80rpx; display: flex; align-items: center; justify-content: center; background: var(--color-card); border-radius: var(--radius-lg); border: 2rpx dashed var(--color-border); color: var(--color-primary); font-size: 28rpx; margin-bottom: 24rpx; }
.btn-press { opacity: 0.7; }

.create-form { background: var(--color-card); border-radius: var(--radius-lg); padding: 24rpx; }
.form-input { height: 80rpx; background: var(--csl-surface-muted); border-radius: var(--radius-md); padding: 0 24rpx; font-size: 28rpx; margin-bottom: 16rpx; display: flex; align-items: center; }
.form-picker { color: var(--color-text); }
.form-section { margin-bottom: 16rpx; }
.form-label { font-size: 26rpx; color: var(--color-text-secondary); margin-bottom: 8rpx; display: block; }
.icon-row, .color-row { display: flex; gap: 12rpx; flex-wrap: wrap; }
.icon-opt { width: 60rpx; height: 60rpx; display: flex; align-items: center; justify-content: center; background: var(--csl-surface-muted); border-radius: var(--radius-md); font-size: 28rpx; }
.icon-sel { background: var(--color-primary-bg); border: 2rpx solid var(--color-primary); }
.color-opt { width: 48rpx; height: 48rpx; border-radius: 50%; border: 3rpx solid transparent; }
.color-sel { border-color: var(--color-text); transform: scale(1.2); }
.submit-btn { height: 80rpx; display: flex; align-items: center; justify-content: center; background: var(--csl-gradient); border-radius: var(--radius-lg); color: #FFF; font-size: 28rpx; font-weight: 600; }
