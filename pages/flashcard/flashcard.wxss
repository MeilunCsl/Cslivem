/* pages/flashcard/flashcard.wxss */
.page { height: 100vh; background: var(--color-bg); display: flex; flex-direction: column; }
.nav-bar { display: flex; align-items: center; height: 88rpx; padding: 0 24rpx; background: var(--color-card); border-bottom: 1rpx solid var(--color-divider); }
.nav-back { font-size: 48rpx; color: var(--color-primary); padding: 0 16rpx; }
.nav-title { flex: 1; text-align: center; font-size: 32rpx; font-weight: 600; color: var(--color-text); }
.content { flex: 1; padding: 24rpx var(--csl-page-x); }

.stats-bar { display: flex; gap: 16rpx; margin-bottom: 24rpx; }
.stat-item { flex: 1; background: var(--color-card); border-radius: var(--radius-lg); padding: 20rpx; text-align: center; }
.stat-val { display: block; font-size: 36rpx; font-weight: 700; color: var(--color-primary); }
.stat-lbl { display: block; font-size: 22rpx; color: var(--color-text-secondary); margin-top: 4rpx; }

.deck-list { margin-bottom: 20rpx; }
.deck-card { display: flex; align-items: center; padding: 24rpx; background: var(--color-card); border-radius: var(--radius-lg); margin-bottom: 12rpx; }
.deck-press { transform: scale(0.98); }
.deck-info { flex: 1; }
.deck-name { display: block; font-size: 30rpx; font-weight: 600; color: var(--color-text); }
.deck-meta { display: block; font-size: 22rpx; color: var(--color-text-secondary); margin-top: 4rpx; }
.deck-del { padding: 8rpx 12rpx; font-size: 28rpx; color: var(--color-text-secondary); }

.empty-state { display: flex; flex-direction: column; align-items: center; padding: 80rpx 0; }
.empty-icon { font-size: 64rpx; color: var(--color-text-secondary); margin-bottom: 16rpx; }
.empty-text { font-size: 28rpx; color: var(--color-text-secondary); }

.create-btn { height: 72rpx; display: flex; align-items: center; justify-content: center; background: var(--color-card); border-radius: var(--radius-md); border: 2rpx dashed var(--color-border); color: var(--color-primary); font-size: 26rpx; margin-bottom: 16rpx; }
.btn-press { opacity: 0.7; }
.create-form { background: var(--color-card); border-radius: var(--radius-lg); padding: 24rpx; margin-bottom: 20rpx; }
.form-input { height: 72rpx; background: var(--csl-surface-muted); border-radius: var(--radius-md); padding: 0 24rpx; font-size: 26rpx; margin-bottom: 12rpx; }
.submit-btn { height: 72rpx; display: flex; align-items: center; justify-content: center; background: var(--csl-gradient); border-radius: var(--radius-md); color: #FFF; font-size: 28rpx; font-weight: 600; }

.detail-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx; }
.detail-count { font-size: 28rpx; color: var(--color-text-secondary); }
.review-btn { padding: 16rpx 32rpx; background: var(--csl-gradient); border-radius: var(--radius-full); color: #FFF; font-size: 28rpx; font-weight: 600; }

.review-area { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 40rpx var(--csl-page-x); }
.review-progress { font-size: 24rpx; color: var(--color-text-secondary); margin-bottom: 32rpx; }

.flashcard { width: 560rpx; height: 400rpx; perspective: 1000rpx; margin-bottom: 40rpx; position: relative; }
.card-face { position: absolute; width: 100%; height: 100%; backface-visibility: hidden; border-radius: var(--radius-xl); display: flex; align-items: center; justify-content: center; padding: 40rpx; transition: transform 0.5s ease; }
.card-front { background: var(--color-card); border: 2rpx solid var(--color-border); transform: rotateY(0deg); }
.card-back { background: var(--color-primary); transform: rotateY(180deg); }
.flipped .card-front { transform: rotateY(-180deg); }
.flipped .card-back { transform: rotateY(0deg); }
.card-text { font-size: 32rpx; text-align: center; line-height: 1.6; }
.card-front .card-text { color: var(--color-text); }
.card-back .card-text { color: #FFF; }

.rating-btns { display: flex; gap: 24rpx; }
.rate-btn { padding: 20rpx 40rpx; border-radius: var(--radius-full); font-size: 28rpx; font-weight: 600; }
.rate-hard { background: #FFF0F0; color: #FF6B6B; }
.rate-ok { background: #FFF8E1; color: #F59E0B; }
.rate-easy { background: #E8F5E9; color: #24A148; }
