/* pages/note-editor/note-editor.wxss */
.page { height: 100vh; background: var(--color-bg); display: flex; flex-direction: column; }

.top-bar { display: flex; justify-content: space-between; align-items: center; padding: 16rpx 32rpx; }
.back-btn { font-size: 28rpx; color: var(--color-text-secondary); padding: 12rpx 0; }
.save-btn { font-size: 28rpx; color: var(--color-primary); font-weight: 600; padding: 12rpx 24rpx; background: rgba(91, 76, 255, 0.08); border-radius: var(--radius-full); }
.press { opacity: 0.6; }

.title-section { padding: 16rpx 32rpx; }
.title-input { font-size: var(--font-size-title-lg); font-weight: 700; color: var(--color-text); width: 100%; padding: 12rpx 0; border-bottom: 2rpx solid rgba(91, 76, 255, 0.15); }

.toolbar { display: flex; gap: 4rpx; padding: 16rpx 32rpx; background: var(--color-card); border-top: 1rpx solid var(--csl-border); border-bottom: 1rpx solid var(--csl-border); }
.toolbar-item { width: 64rpx; height: 64rpx; display: flex; align-items: center; justify-content: center; font-size: 28rpx; color: var(--color-text-secondary); border-radius: var(--radius-sm); transition: all 0.2s ease; }
.toolbar-item:active { background: rgba(91, 76, 255, 0.08); color: var(--color-primary); }

.editor-section { flex: 1; padding: 24rpx 32rpx; overflow-y: auto; }
.editor { width: 100%; min-height: 500rpx; font-size: var(--font-size-body); color: var(--color-text); line-height: 1.8; padding: 16rpx 0; }

.anim-fade { opacity: 0; transform: translateY(24rpx); transition: opacity 0.5s ease, transform 0.5s var(--ease-spring); }
.anim-show { opacity: 1; transform: translateY(0); }
.anim-d1 { transition-delay: 0.08s; }
.anim-d2 { transition-delay: 0.16s; }
.anim-d3 { transition-delay: 0.24s; }