/* pages/note-editor/note-editor.wxss */
.page { height: 100vh; background: var(--color-bg); display: flex; flex-direction: column; }

.top-bar { display: flex; justify-content: space-between; align-items: center; padding: 16rpx 32rpx; }
.back-btn { font-size: 28rpx; color: var(--color-text-secondary); padding: 12rpx 0; }
.save-btn { font-size: 28rpx; color: var(--color-primary); font-weight: 600; padding: 12rpx 24rpx; background: rgba(91, 76, 255, 0.08); border-radius: var(--radius-full); }
.press { opacity: 0.6; }

.title-section { padding: 16rpx 32rpx; }
.title-input { font-size: var(--font-size-title-lg); font-weight: 700; color: var(--color-text); width: 100%; padding: 12rpx 0; border-bottom: 2rpx solid rgba(91, 76, 255, 0.15); }

.toolbar { display: flex; gap: 4rpx; padding: 16rpx 32rpx; background: var(--color-card); border-top: 1rpx solid var(--color-border); border-bottom: 1rpx solid var(--color-border); }
.toolbar-item { width: 64rpx; height: 64rpx; display: flex; align-items: center; justify-content: center; font-size: 28rpx; color: var(--color-text-secondary); border-radius: var(--radius-sm); transition: all 0.2s ease; }
.toolbar-item:active { background: rgba(91, 76, 255, 0.08); color: var(--color-primary); }

.editor-section { flex: 1; padding: 24rpx 32rpx; overflow-y: auto; }
.editor { width: 100%; min-height: 500rpx; font-size: var(--font-size-body); color: var(--color-text); line-height: 1.8; padding: 16rpx 0; }

.anim-fade { opacity: 0; transform: translateY(24rpx); transition: opacity 0.5s ease, transform 0.5s var(--ease-spring); }
.anim-show { opacity: 1; transform: translateY(0); }
.anim-d1 { transition-delay: 0.08s; }
.anim-d2 { transition-delay: 0.16s; }
.anim-d3 { transition-delay: 0.24s; }

/* Wiki-Link Suggestions Panel */
.suggestions-panel {
  position: fixed; left: 32rpx; right: 32rpx;
  bottom: calc(120rpx + env(safe-area-inset-bottom));
  background: var(--color-card); border-radius: var(--radius-lg);
  box-shadow: 0 -4rpx 24rpx rgba(10,15,26,0.12);
  max-height: 400rpx; z-index: 90;
  transform: translateY(20rpx); opacity: 0;
  transition: transform 0.2s var(--ease-spring), opacity 0.2s ease;
  pointer-events: none;
}
.suggestions-panel.show { transform: translateY(0); opacity: 1; pointer-events: auto; }
.suggestions-header { padding: 16rpx 24rpx; font-size: 24rpx; color: var(--color-text-secondary); border-bottom: 1rpx solid var(--color-divider); }
.suggestions-list { max-height: 320rpx; }
.suggestion-item { display: flex; align-items: center; gap: 12rpx; padding: 16rpx 24rpx; }
.suggestion-item:active, .suggestion-press { background: var(--csl-surface-muted); }
.suggestion-icon { font-size: 28rpx; flex-shrink: 0; }
.suggestion-label { flex: 1; font-size: 28rpx; color: var(--color-text); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.suggestion-type { font-size: 20rpx; color: var(--color-text-placeholder); padding: 2rpx 12rpx; background: var(--csl-surface-muted); border-radius: var(--radius-sm); }

/* AI Assist Toolbar */
.ai-toolbar { display: flex; gap: 12rpx; padding: 12rpx 0; border-top: 1rpx solid var(--color-divider); }
.ai-btn {
  display: flex; align-items: center; gap: 6rpx;
  padding: 10rpx 20rpx; border-radius: var(--radius-full);
  background: var(--color-primary-bg); transition: transform 0.15s ease;
}
.ai-btn:active, .press { transform: scale(0.94); }
.ai-btn-icon { font-size: 24rpx; }
.ai-btn-text { font-size: 22rpx; color: var(--color-primary); font-weight: 600; }
