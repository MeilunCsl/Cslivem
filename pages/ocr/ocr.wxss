/* pages/ocr/ocr.wxss */
.page { height: 100vh; background: var(--color-bg); display: flex; flex-direction: column; }
.nav-bar { display: flex; align-items: center; height: 88rpx; padding: 0 24rpx; background: var(--color-card); border-bottom: 1rpx solid var(--color-divider); }
.nav-back { font-size: 48rpx; color: var(--color-primary); padding: 0 16rpx; }
.nav-title { flex: 1; text-align: center; font-size: 32rpx; font-weight: 600; color: var(--color-text); }

.content { flex: 1; padding: 32rpx var(--csl-page-x); overflow-y: auto; }

.preview-section { margin-bottom: 32rpx; border-radius: var(--radius-lg); overflow: hidden; background: var(--color-card); }
.preview-image { width: 100%; height: 400rpx; }

.source-section { display: flex; gap: 24rpx; justify-content: center; padding: 80rpx 0; }
.source-btn { display: flex; flex-direction: column; align-items: center; gap: 16rpx; padding: 48rpx; background: var(--color-card); border-radius: var(--radius-lg); border: 2rpx solid var(--color-border); flex: 1; transition: all 0.2s ease; }
.source-press { transform: scale(0.96); border-color: var(--color-primary); }
.source-icon { font-size: 64rpx; }
.source-text { font-size: 28rpx; color: var(--color-text); font-weight: 500; }

.action-section { display: flex; flex-direction: column; gap: 16rpx; padding: 24rpx 0; }
.recognize-btn { height: 88rpx; display: flex; align-items: center; justify-content: center; background: var(--csl-gradient); border-radius: var(--radius-lg); color: #FFF; font-size: 30rpx; font-weight: 600; }
.recognize-press { opacity: 0.8; }
.reselect-btn { height: 72rpx; display: flex; align-items: center; justify-content: center; background: var(--color-card); border-radius: var(--radius-lg); color: var(--color-text-secondary); font-size: 28rpx; border: 2rpx solid var(--color-border); }

.loading-section { display: flex; flex-direction: column; align-items: center; padding: 80rpx 0; gap: 24rpx; }
.loading-dots { display: flex; gap: 8rpx; }
.dot { width: 12rpx; height: 12rpx; border-radius: 50%; background: var(--color-primary); animation: bounce 1.4s ease-in-out infinite; }
.dot1 { animation-delay: 0s; }
.dot2 { animation-delay: 0.2s; }
.dot3 { animation-delay: 0.4s; }
@keyframes bounce { 0%, 80%, 100% { transform: translateY(0); opacity: 0.4; } 40% { transform: translateY(-12rpx); opacity: 1; } }
.loading-text { font-size: 28rpx; color: var(--color-text-secondary); }

.result-section { padding: 24rpx 0; }
.result-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.result-title { font-size: 30rpx; font-weight: 600; color: var(--color-text); }
.result-mode { font-size: 22rpx; color: var(--color-primary); background: var(--color-primary-bg); padding: 4rpx 12rpx; border-radius: var(--radius-full); }

.result-content { background: var(--color-card); border-radius: var(--radius-lg); padding: 24rpx; margin-bottom: 24rpx; min-height: 200rpx; }
.result-text { font-size: 28rpx; color: var(--color-text); line-height: 1.8; white-space: pre-wrap; }

.result-actions { display: flex; gap: 16rpx; margin-bottom: 24rpx; }
.result-btn { flex: 1; height: 80rpx; display: flex; align-items: center; justify-content: center; background: var(--color-card); border-radius: var(--radius-lg); font-size: 28rpx; color: var(--color-text); border: 2rpx solid var(--color-border); }
.result-btn-primary { background: var(--csl-gradient); color: #FFF; border: none; }

.new-ocr { text-align: center; padding: 24rpx; color: var(--color-primary); font-size: 28rpx; }
