/* pages/graph-ingest/graph-ingest.wxss */
.page { height: 100vh; background: var(--color-bg); display: flex; flex-direction: column; }
.nav-bar { display: flex; align-items: center; height: 88rpx; padding: 0 24rpx; background: var(--color-card); border-bottom: 1rpx solid var(--color-divider); }
.nav-back { font-size: 48rpx; color: var(--color-primary); padding: 0 16rpx; }
.nav-title { flex: 1; text-align: center; font-size: 32rpx; font-weight: 600; color: var(--color-text); }

.content { flex: 1; padding: 24rpx var(--csl-page-x); overflow-y: auto; }

.loading { display: flex; justify-content: center; padding: 120rpx 0; }
.loading-text { font-size: 28rpx; color: var(--color-text-secondary); }

.section { background: var(--color-card); border-radius: var(--radius-lg); padding: 24rpx; margin-bottom: 24rpx; }
.section-header { margin-bottom: 16rpx; }
.section-title { font-size: 28rpx; font-weight: 600; color: var(--color-text); }

.node-list { display: flex; flex-direction: column; gap: 12rpx; }
.node-item { display: flex; align-items: center; padding: 16rpx; border-radius: var(--radius-md); border: 2rpx solid var(--color-border); transition: all 0.2s ease; }
.node-selected { border-color: var(--color-primary); background: rgba(91, 76, 255, 0.04); }
.node-deselected { opacity: 0.5; }

.node-check { width: 40rpx; height: 40rpx; border-radius: 50%; border: 2rpx solid var(--color-border); display: flex; align-items: center; justify-content: center; margin-right: 16rpx; flex-shrink: 0; }
.node-selected .node-check { background: var(--color-primary); border-color: var(--color-primary); }
.check-icon { font-size: 24rpx; color: #FFF; }

.node-info { flex: 1; display: flex; flex-direction: column; }
.node-type { font-size: 20rpx; color: var(--color-primary); font-weight: 500; margin-bottom: 4rpx; }
.type-concept { color: #5B4CFF; }
.type-entity { color: #3A7BFF; }
.type-topic { color: #00D4D9; }
.node-label { font-size: 28rpx; color: var(--color-text); }
.node-dup { font-size: 22rpx; color: var(--color-warning); margin-top: 4rpx; }

.edge-list { display: flex; flex-direction: column; gap: 8rpx; }
.edge-item { display: flex; align-items: center; padding: 12rpx 16rpx; background: var(--csl-surface-muted); border-radius: var(--radius-md); font-size: 24rpx; }
.edge-source { color: var(--color-primary); font-weight: 500; }
.edge-arrow { color: var(--color-text-secondary); margin: 0 8rpx; }
.edge-target { color: var(--color-text); font-weight: 500; }
.edge-type { margin-left: auto; font-size: 20rpx; color: var(--color-text-placeholder); background: var(--color-card); padding: 4rpx 12rpx; border-radius: var(--radius-full); }

.empty { display: flex; flex-direction: column; align-items: center; padding: 120rpx 0; }
.empty-icon { font-size: 80rpx; margin-bottom: 20rpx; opacity: 0.3; }
.empty-text { font-size: 28rpx; color: var(--color-text-secondary); }

.actions { padding: 24rpx 0; }
.confirm-btn { height: 88rpx; display: flex; align-items: center; justify-content: center; background: var(--csl-gradient); border-radius: var(--radius-lg); color: #FFF; font-size: 30rpx; font-weight: 600; transition: opacity 0.2s ease; }
.btn-disabled { opacity: 0.4; }
.confirm-btn:active { opacity: 0.8; }

.ingested-info { display: flex; align-items: center; justify-content: center; padding: 48rpx 0; gap: 12rpx; }
.ingested-icon { font-size: 48rpx; }
.ingested-text { font-size: 30rpx; color: var(--color-success); font-weight: 600; }
