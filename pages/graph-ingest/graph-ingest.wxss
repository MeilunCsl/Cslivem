.page { height: 100vh; background: var(--color-bg); }
.nav-bar { display: flex; align-items: center; height: 88rpx; padding: 0 24rpx; background: var(--color-card); }
.nav-back { font-size: 48rpx; color: var(--color-primary); padding: 0 16rpx; }
.nav-title { flex: 1; text-align: center; font-size: 32rpx; font-weight: 600; }
.content { padding: 32rpx; }
.section { background: var(--color-card); border-radius: 20rpx; padding: 24rpx; margin-bottom: 20rpx; }
.section-title { font-size: 28rpx; font-weight: 600; color: var(--color-text); display: block; margin-bottom: 16rpx; }
.node-list { display: flex; flex-direction: column; gap: 12rpx; }
.node-item { display: flex; align-items: center; gap: 12rpx; padding: 12rpx 16rpx; background: var(--csl-surface-muted); border-radius: 12rpx; }
.node-type { font-size: 20rpx; color: var(--color-primary); background: var(--color-primary-bg); padding: 4rpx 12rpx; border-radius: 8rpx; }
.node-label { font-size: 26rpx; color: var(--color-text); }
.confirm-btn { display: flex; align-items: center; justify-content: center; height: 88rpx; background: var(--csl-gradient); border-radius: 44rpx; color: #FFF; font-size: 30rpx; font-weight: 600; margin-top: 32rpx; }
.ingested-info { text-align: center; padding: 32rpx; color: var(--color-success); font-size: 28rpx; }
.page { padding-bottom: env(safe-area-inset-bottom); }
