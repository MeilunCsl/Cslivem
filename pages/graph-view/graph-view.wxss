/* pages/graph-view/graph-view.wxss */
.page { height: 100vh; background: #F7F8FB; display: flex; flex-direction: column; }

.header {
  display: flex; align-items: center; gap: 16rpx;
  padding: 16rpx var(--csl-page-x);
  background: var(--color-card); border-bottom: 1rpx solid var(--color-divider);
}
.back-btn { font-size: 36rpx; color: var(--color-primary); padding: 8rpx 12rpx; }
.btn-press { transform: scale(0.85); opacity: 0.7; }
.header-title { font-size: 32rpx; font-weight: 700; color: var(--color-text); flex: 1; }
.stats { display: flex; gap: 16rpx; }
.stat { font-size: 22rpx; color: var(--color-text-secondary); }

.anim-fade { opacity: 0; transform: translateY(20rpx); transition: opacity 0.4s ease, transform 0.4s var(--ease-spring); }
.anim-show { opacity: 1; transform: translateY(0); }

.graph-canvas { flex: 1; width: 100%; }

.node-info {
  position: fixed; left: 32rpx; right: 32rpx;
  bottom: calc(32rpx + env(safe-area-inset-bottom));
  background: var(--color-card); border-radius: var(--radius-lg);
  padding: 24rpx 32rpx; box-shadow: var(--shadow-card);
  transform: translateY(200rpx); opacity: 0;
  transition: transform 0.3s var(--ease-spring), opacity 0.3s ease;
}
.node-info.show { transform: translateY(0); opacity: 1; }
.node-info-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16rpx; }
.node-label { font-size: 30rpx; font-weight: 700; color: var(--color-text); }
.node-type {
  font-size: 22rpx; color: var(--color-primary); padding: 4rpx 16rpx;
  background: var(--color-primary-bg); border-radius: var(--radius-full);
}
.node-action {
  padding: 16rpx; text-align: center; color: var(--color-primary);
  font-size: 28rpx; font-weight: 600; border-radius: var(--radius-md);
  background: var(--color-primary-bg);
}
.action-press { transform: scale(0.96); opacity: 0.8; }
