/* pages/graph-view/graph-view.wxss */
.page { height: 100vh; background: var(--color-bg); display: flex; flex-direction: column; }

.header {
  display: flex; align-items: center; gap: 12rpx;
  padding: 16rpx 32rpx;
  background: var(--color-card); border-bottom: 1rpx solid var(--color-divider);
}
.back-btn { font-size: 36rpx; color: var(--color-primary); padding: 8rpx 12rpx; }
.btn-press { transform: scale(0.85); opacity: 0.7; }
.header-title { font-size: 32rpx; font-weight: 700; color: var(--color-text); flex: 1; }
.header-actions { display: flex; align-items: center; gap: 16rpx; }
.search-toggle { font-size: 32rpx; padding: 8rpx; }
.stats { font-size: 24rpx; color: var(--color-text-secondary); }

.anim-fade { opacity: 0; transform: translateY(20rpx); transition: opacity 0.4s ease, transform 0.4s var(--ease-spring); }
.anim-show { opacity: 1; transform: translateY(0); }

/* Search Bar */
.search-bar {
  background: var(--color-card); padding: 12rpx 32rpx;
  border-bottom: 1rpx solid var(--color-divider);
  max-height: 0; overflow: hidden; transition: max-height 0.3s ease;
}
.search-bar.show { max-height: 500rpx; }
.search-input {
  height: 72rpx; background: var(--csl-surface-muted); border-radius: var(--radius-full);
  padding: 0 28rpx; font-size: 28rpx;
}
.search-results { margin-top: 12rpx; max-height: 300rpx; }
.search-item { display: flex; align-items: center; gap: 12rpx; padding: 12rpx 0; }
.item-press { opacity: 0.7; }
.search-dot { width: 12rpx; height: 12rpx; border-radius: 50%; flex-shrink: 0; }
.search-label { flex: 1; font-size: 26rpx; color: var(--color-text); }
.search-type { font-size: 20rpx; color: var(--color-text-placeholder); }

/* Canvas */
.graph-canvas { flex: 1; width: 100%; }

/* Node Info */
.node-info {
  position: fixed; left: 32rpx; right: 32rpx;
  bottom: calc(32rpx + env(safe-area-inset-bottom));
  background: var(--color-card); border-radius: var(--radius-lg);
  padding: 24rpx 32rpx; box-shadow: var(--shadow-card);
  transform: translateY(200rpx); opacity: 0;
  transition: transform 0.3s var(--ease-spring), opacity 0.3s ease;
}
.node-info.show { transform: translateY(0); opacity: 1; }
.node-info-header { display: flex; align-items: center; gap: 16rpx; margin-bottom: 16rpx; }
.node-dot { width: 16rpx; height: 16rpx; border-radius: 50%; flex-shrink: 0; }
.node-info-text { flex: 1; }
.node-label { display: block; font-size: 30rpx; font-weight: 700; color: var(--color-text); }
.node-type { display: block; font-size: 22rpx; color: var(--color-text-secondary); margin-top: 4rpx; }
.node-actions { display: flex; gap: 12rpx; }
.node-action {
  flex: 1; padding: 16rpx; text-align: center; color: var(--color-primary);
  font-size: 28rpx; font-weight: 600; border-radius: var(--radius-md);
  background: var(--color-primary-bg);
}
.action-press { transform: scale(0.96); opacity: 0.8; }

/* Neighbor List */
.neighbor-list { margin-bottom: 16rpx; }
.neighbor-title { font-size: 22rpx; color: var(--color-text-secondary); margin-bottom: 10rpx; display: block; }
.neighbor-items { display: flex; flex-wrap: wrap; gap: 10rpx; }
.neighbor-chip {
  display: flex; align-items: center; gap: 8rpx;
  padding: 10rpx 18rpx; background: var(--csl-surface-muted);
  border-radius: var(--radius-full); border: 1rpx solid var(--color-border);
  transition: all 0.15s ease;
}
.neighbor-chip:active { transform: scale(0.95); border-color: var(--color-primary); }
.neighbor-dot { width: 10rpx; height: 10rpx; border-radius: 50%; flex-shrink: 0; }
.neighbor-name { font-size: 22rpx; color: var(--color-text); }
.chip-press { transform: scale(0.95); border-color: var(--color-primary); }
