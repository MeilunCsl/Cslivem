<!-- pages/tools/tools.wxml -->
<view class="page">
  <view style="height: {{statusBarHeight}}px;"></view>
  <scroll-view scroll-y class="page-scroll" enhanced show-scrollbar="{{false}}">
    <view class="page-container">
      <view class="header anim-fade {{ready ? 'anim-show' : ''}}">
        <text class="page-title">工具中心</text>
      </view>

      <view class="search-section anim-fade anim-d1 {{ready ? 'anim-show' : ''}}">
        <search-input placeholder="搜索工具..." showAi="{{false}}" />
      </view>

      <view class="section anim-fade anim-d2 {{ready ? 'anim-show' : ''}}">
        <view class="section-header">
          <text class="section-title">常用</text>
        </view>
        <view class="tools-grid">
          <card className="tool-card" wx:for="{{tools}}" wx:key="id" bindtap="onToolTap" data-id="{{item.id}}" hover-class="tool-press">
            <view class="tool-icon">{{item.icon}}</view>
            <text class="tool-name">{{item.name}}</text>
            <text class="tool-desc">{{item.description}}</text>
          </card>
        </view>
      </view>


      <!-- Settings Entry -->
      <view class="section anim-fade anim-d2 {{ready ? 'anim-show' : ''}}">
        <view class="settings-entry" bindtap="onSettingsTap" hover-class="coming-press">
          <view class="settings-icon-wrap">
            <text class="settings-icon-text">⚙</text>
          </view>
          <view class="settings-info">
            <text class="settings-name">设置</text>
            <text class="settings-desc">AI 模型、ECS 同步、数据管理</text>
          </view>
          <text class="settings-arrow">›</text>
        </view>
      </view>
      <view class="section anim-fade anim-d3 {{ready ? 'anim-show' : ''}}">
        <view class="section-header">
          <text class="section-title">更多工具</text>
          <text class="section-sub">开发中</text>
        </view>
        <view class="coming-soon-grid">
          <view class="coming-item" wx:for="{{comingSoon}}" wx:key="id" hover-class="coming-press">
            <text class="coming-icon">{{item.icon}}</text>
            <text class="coming-name">{{item.name}}</text>
          </view>
        </view>

      <view class="section anim-fade anim-d2" wx:if="{{storageInfo}}">
        <view class="section-header">
          <text class="section-title">存储统计</text>
        </view>
        <view class="storage-grid">
          <view class="storage-item">
            <text class="storage-value">{{storageInfo.conversations}}</text>
            <text class="storage-label">对话</text>
          </view>
          <view class="storage-item">
            <text class="storage-value">{{storageInfo.messages}}</text>
            <text class="storage-label">消息</text>
          </view>
          <view class="storage-item">
            <text class="storage-value">{{storageInfo.assets}}</text>
            <text class="storage-label">附件</text>
          </view>
          <view class="storage-item">
            <text class="storage-value">{{storageInfo.storageKB}}KB</text>
            <text class="storage-label">占用</text>
          </view>
        </view>
      </view>
      </view>
    </view>
  </scroll-view>
  <custom-tabbar selected="{{3}}" />
</view>