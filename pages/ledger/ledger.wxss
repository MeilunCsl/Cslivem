/* pages/ledger/ledger.wxss */
.page { height: 100vh; background: var(--color-bg); display: flex; flex-direction: column; }
.page-scroll { flex: 1; height: 0; }
.page-container { padding: 16rpx var(--csl-page-x) 240rpx; }
.header { padding: 24rpx 0 8rpx; }
.page-title { font-size: var(--font-size-title-lg); font-weight: 700; color: var(--color-text); }

.anim-fade { opacity: 0; transform: translateY(24rpx); transition: opacity 0.5s ease, transform 0.5s var(--ease-spring); }
.anim-show { opacity: 1; transform: translateY(0); }
.anim-d1 { transition-delay: 0.08s; }
.anim-d2 { transition-delay: 0.16s; }
.anim-d3 { transition-delay: 0.24s; }

/* Month Nav */
.month-nav { display: flex; align-items: center; justify-content: center; gap: 40rpx; margin: 20rpx 0; }
.month-arrow { font-size: 40rpx; color: var(--color-primary); padding: 10rpx 20rpx; transition: transform 0.2s ease; }
.arrow-press { transform: scale(0.8); opacity: 0.6; }
.month-label { font-size: 32rpx; font-weight: 700; color: var(--color-text); }

/* Summary Card */
.summary-card {
  background: var(--color-card); border-radius: var(--radius-lg); padding: 32rpx;
  box-shadow: var(--shadow-card); margin-bottom: 24rpx;
}
.summary-row { display: flex; align-items: center; justify-content: space-around; }
.summary-item { display: flex; flex-direction: column; align-items: center; gap: 8rpx; }
.summary-label { font-size: 24rpx; color: var(--color-text-secondary); }
.summary-amount { font-size: 32rpx; font-weight: 700; color: var(--color-text); }
.summary-amount.income { color: var(--color-success); }
.summary-amount.expense { color: var(--color-error); }
.summary-divider { width: 1rpx; height: 48rpx; background: var(--color-divider); }

/* Section */
.section { margin-bottom: 24rpx; }
.section-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.section-title { font-size: var(--font-size-title-md); font-weight: 700; color: var(--color-text); }

/* Accounts Scroll */
.accounts-scroll { white-space: nowrap; }
.accounts-row { display: inline-flex; gap: 16rpx; padding: 4rpx 0; }
.account-chip {
  display: inline-flex; align-items: center; gap: 12rpx;
  background: var(--color-card); border-radius: var(--radius-md); padding: 16rpx 24rpx;
  box-shadow: var(--shadow-card);
}
.account-icon { font-size: 32rpx; }
.account-name { font-size: 26rpx; font-weight: 600; color: var(--color-text); }
.account-balance { font-size: 24rpx; color: var(--color-text-secondary); }

/* Transaction List */
.tx-card { margin-bottom: 12rpx; }
.tx-item { display: flex; align-items: center; gap: 16rpx; }
.tx-icon-wrap {
  width: 56rpx; height: 56rpx; border-radius: 16rpx; background: var(--csl-surface-muted);
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
}
.tx-icon { font-size: 28rpx; }
.tx-info { flex: 1; min-width: 0; }
.tx-cat { display: block; font-size: 28rpx; font-weight: 600; color: var(--color-text); }
.tx-note { display: block; font-size: 22rpx; color: var(--color-text-secondary); margin-top: 2rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.tx-date { display: block; font-size: 20rpx; color: var(--color-text-placeholder); margin-top: 2rpx; }
.tx-amount { font-size: 30rpx; font-weight: 700; flex-shrink: 0; }
.tx-amount.income { color: var(--color-success); }
.tx-amount.expense { color: var(--color-error); }
.tx-delete {
  width: 48rpx; height: 48rpx; display: flex; align-items: center; justify-content: center;
  font-size: 28rpx; color: var(--color-text-secondary); border-radius: 50%; flex-shrink: 0;
}
.tx-delete:active { background: rgba(220,53,69,0.1); color: var(--color-error); }
.empty-mini { text-align: center; padding: 40rpx 0; color: var(--color-text-secondary); font-size: 26rpx; }

/* FAB Create */
.fab-create {
  position: fixed; right: 48rpx; bottom: calc(240rpx + env(safe-area-inset-bottom));
  width: 100rpx; height: 100rpx; border-radius: 50%;
  background: var(--csl-gradient); display: flex; align-items: center; justify-content: center;
  box-shadow: var(--shadow-fab); z-index: 90; transition: transform 0.2s ease, opacity 0.2s ease;
}
.fab-hidden { transform: scale(0); opacity: 0; pointer-events: none; }
.fab-press { transform: scale(0.9); }
.fab-plus { font-size: 52rpx; font-weight: 300; color: #FFFFFF; line-height: 1; }

/* Create Panel */
.create-overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0); z-index: -1; pointer-events: none;
  transition: background 0.28s ease;
}
.create-overlay.show {
  z-index: 99; background: rgba(10,15,26,0.30); pointer-events: auto;
}
.create-panel {
  position: fixed; left: 32rpx; right: 32rpx; bottom: -800rpx;
  background: #FFFFFF; border-radius: 32rpx; padding: 40rpx; padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -8rpx 40rpx rgba(10,15,26,0.08); z-index: 100;
  opacity: 0; pointer-events: none;
  transition: bottom 0.28s cubic-bezier(0.22,1,0.36,1), opacity 0.24s ease;
}
.panel-in {
  bottom: calc(190rpx + env(safe-area-inset-bottom));
  opacity: 1; pointer-events: auto;
}
.panel-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; }
.panel-title { font-size: 32rpx; font-weight: 700; color: var(--color-text); }
.panel-close { font-size: 36rpx; color: var(--color-text-secondary); padding: 8rpx; }

/* Type Tabs */
.type-tabs { display: flex; gap: 16rpx; margin-bottom: 24rpx; }
.type-tab {
  flex: 1; height: 72rpx; display: flex; align-items: center; justify-content: center;
  border-radius: var(--radius-md); font-size: 28rpx; font-weight: 600;
  background: var(--csl-surface-muted); color: var(--color-text-secondary);
  transition: background 0.2s ease, color 0.2s ease;
}
.type-tab.active {
  background: var(--color-primary-bg); color: var(--color-primary);
}

/* Amount */
.amount-row { display: flex; align-items: center; margin-bottom: 24rpx; }
.amount-prefix { font-size: 48rpx; font-weight: 700; color: var(--color-text); margin-right: 12rpx; }
.amount-input { flex: 1; font-size: 48rpx; font-weight: 700; color: var(--color-text); }

/* Category Grid */
.cat-grid { display: flex; flex-wrap: wrap; gap: 16rpx; margin-bottom: 24rpx; }
.cat-item {
  display: flex; flex-direction: column; align-items: center; gap: 6rpx;
  width: calc(25% - 12rpx); padding: 16rpx 0; border-radius: var(--radius-md);
  background: var(--csl-surface-muted); transition: background 0.15s ease;
}
.cat-item.selected { background: var(--color-primary-bg); }
.cat-icon { font-size: 32rpx; }
.cat-name { font-size: 22rpx; color: var(--color-text); }

/* Account Select */
.account-select { margin-bottom: 20rpx; }
.select-label { font-size: 24rpx; color: var(--color-text-secondary); margin-bottom: 12rpx; display: block; }
.account-options { display: flex; flex-wrap: wrap; gap: 12rpx; }
.acct-opt {
  padding: 12rpx 24rpx; border-radius: var(--radius-full);
  background: var(--csl-surface-muted); font-size: 24rpx; color: var(--color-text);
  transition: background 0.15s ease;
}
.acct-opt.selected { background: var(--color-primary-bg); color: var(--color-primary); font-weight: 600; }

/* Note Input */
.note-input {
  width: 100%; height: 72rpx; padding: 0 24rpx; margin-bottom: 24rpx;
  background: var(--csl-surface-muted); border-radius: var(--radius-md);
  font-size: 26rpx; color: var(--color-text); box-sizing: border-box;
}

/* Save Button */
.save-btn {
  width: 100%; height: 88rpx; display: flex; align-items: center; justify-content: center;
  background: var(--csl-gradient); border-radius: var(--radius-full);
  font-size: 30rpx; font-weight: 700; color: #FFFFFF;
  transition: transform 0.15s ease, opacity 0.15s ease;
}
.save-press { transform: scale(0.96); opacity: 0.85; }
